---
import { postUrl } from '../lib/post-url';
import type { Post } from '../lib/db/posts';

interface Props {
  post: Post;
  cover: string;
  description?: string | null;
}
const { post, cover, description } = Astro.props;
---
<a class="card" href={postUrl({ publishedAt: post.publishedAt!, slug: post.slug })}>
  <img loading="lazy" src={cover} alt={post.title} />
  <div class="overlay">
    <div class="title">{post.title}</div>
    <div class="desc">{description ?? post.description ?? ''}</div>
  </div>
</a>
