---
import { env } from 'cloudflare:workers';
import BaseLayout from './BaseLayout.astro';
import { renderPostBody } from '../lib/render';
import type { Post } from '../lib/db/posts';
import { marked } from 'marked';

interface Props { post: Post }
const { post } = Astro.props;

const driver = Astro.locals.db!;
const rewritten = await renderPostBody(driver, post, env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string });
const rendered = await marked.parse(rewritten);
const dateStr = post.publishedAt ? post.publishedAt.toISOString().slice(0, 10) : '';
---
<BaseLayout title={post.title} description={post.description ?? undefined}>
  <article>
    <section class="title"><h2>{post.title}</h2></section>
    <section class="meta">
      <span class="time">
        <time datetime={dateStr}>{dateStr}</time>
      </span>
    </section>
    <section class="post" set:html={rendered}></section>
  </article>
</BaseLayout>

<script>
  import '../scripts/lightbox';
</script>
