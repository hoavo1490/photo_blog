---
interface Props {
  title?: string;
  /** When true, hides the global app header and removes the centered
   *  main padding so the page can own its own chrome (the post editor
   *  ships its own header + status row + sticky bottom toolbar). */
  bare?: boolean;
  /** Active tab in the nav row. When provided, renders the two-row header. */
  activeTab?: 'posts' | 'albums' | 'about';
  /** Primary action button href (row 2 right). Rendered only when both are set. */
  actionHref?: string;
  /** Primary action button label. */
  actionLabel?: string;
}
const { title = 'hoavv editor', bare = false, activeTab, actionHref, actionLabel } = Astro.props;
const session = Astro.locals.session;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#111" />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
    <link rel="icon" href="data:," />
    <style is:global>
      :root {
        /* Zinc palette: high-contrast text on near-white, subtle borders,
           muted text that still meets WCAG 4.5:1 on white. */
        --bg: #fafafa;
        --bg-elev: #ffffff;
        --bg-sunken: #f4f4f5;
        --fg: #09090b;        /* zinc-950 */
        --muted: #52525b;     /* zinc-600 -- 7.5:1 on white */
        --muted-2: #a1a1aa;   /* zinc-400, decorative only */
        --border: #e4e4e7;    /* zinc-200 */
        --border-strong: #d4d4d8; /* zinc-300 */
        --accent: #18181b;    /* zinc-900 */
        --accent-fg: #ffffff;
        --danger: #dc2626;    /* red-600 */
        --safe-bottom: env(safe-area-inset-bottom);
        --safe-top: env(safe-area-inset-top);
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { background: var(--bg); color: var(--fg); }
      body {
        font: 16px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        min-height: 100dvh;
        padding-bottom: calc(72px + var(--safe-bottom));
      }
      a { color: inherit; text-decoration: none; }
      a:hover { color: #444; }
      input, textarea, button { font: inherit; color: inherit; }
      input, textarea {
        background: var(--bg-elev); border: 1px solid var(--border);
        border-radius: 8px; padding: 12px 14px; width: 100%; font-size: 16px;
      }
      input:focus, textarea:focus { outline: 2px solid #111; outline-offset: -1px; }
      button {
        min-height: 44px; padding: 10px 16px;
        border: 1px solid var(--border); border-radius: 999px;
        background: var(--bg-elev); cursor: pointer;
      }
      button.primary { background: var(--accent); color: var(--accent-fg); border-color: var(--accent); }
      button.danger { color: var(--danger); border-color: var(--danger); }
      button:disabled { opacity: .5; cursor: not-allowed; }
      .app-header {
        background: var(--bg-elev);
        position: sticky; top: 0; z-index: 10;
        border-bottom: 1px solid var(--border);
      }
      .app-header-identity {
        display: flex; align-items: center; justify-content: space-between;
        padding: calc(var(--safe-top) + 12px) 16px 12px;
      }
      .app-header-identity h1 { font-size: 17px; font-weight: 600; }
      .app-header-identity .who { font-size: 13px; color: var(--muted); }
      .app-header-nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 16px;
        border-top: 1px solid var(--border);
        gap: 8px;
      }
      .app-header-nav .tabs {
        display: flex; align-items: center; gap: 0;
      }
      .app-header-nav .tab {
        display: inline-flex; align-items: center;
        padding: 10px 14px;
        font-size: 14px; font-weight: 500;
        color: var(--muted);
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        text-decoration: none;
      }
      .app-header-nav .tab:hover { color: var(--fg); }
      .app-header-nav .tab.active {
        color: var(--fg); font-weight: 600;
        border-bottom-color: var(--fg);
      }
      .app-header-nav .nav-action {
        min-height: 36px; padding: 6px 14px;
        background: var(--accent); color: var(--accent-fg);
        border: none; border-radius: 999px;
        font-size: 13px; font-weight: 600;
        display: inline-flex; align-items: center;
        text-decoration: none; cursor: pointer;
        white-space: nowrap;
      }
      main { padding: 16px; max-width: 720px; margin: 0 auto; }
      main.bare { padding: 0; max-width: none; margin: 0; }
      .save-bar {
        position: fixed; left: 0; right: 0; bottom: 0;
        padding: 12px 16px calc(12px + var(--safe-bottom));
        background: var(--bg-elev); border-top: 1px solid var(--border);
        display: flex; gap: 8px; justify-content: space-between; z-index: 10;
      }
      .save-bar > .right { display: flex; gap: 8px; }
    </style>
  </head>
  <body>
    {!bare && (
      <header class="app-header">
        <div class="app-header-identity">
          <h1><a href="/admin">hoavv editor</a></h1>
          {session && <span class="who">{session.githubLogin} · <a href="/logout">sign out</a></span>}
        </div>
        {activeTab && (
          <div class="app-header-nav">
            <nav class="tabs" aria-label="Admin navigation">
              <a href="/admin" class={`tab${activeTab === 'posts' ? ' active' : ''}`}>posts</a>
              <a href="/admin/gallery" class={`tab${activeTab === 'albums' ? ' active' : ''}`}>albums</a>
              <a href="/admin/about" class={`tab${activeTab === 'about' ? ' active' : ''}`}>about</a>
            </nav>
            {actionHref && actionLabel && (
              <a href={actionHref} class="nav-action">{actionLabel}</a>
            )}
          </div>
        )}
      </header>
    )}
    <main class={bare ? 'bare' : ''}>
      <slot />
    </main>
  </body>
</html>
