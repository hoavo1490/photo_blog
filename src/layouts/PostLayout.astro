---
import { env } from 'cloudflare:workers';
import BaseLayout from './BaseLayout.astro';
import { coverUrlFor, buildBodyImageResolver } from '../lib/render';
import * as tagsRepo from '../lib/db/tags';
import { firstParagraph, firstBodyImageInfo, rewriteImageTokens } from '../lib/markdown';
import { sanitizePostHtml } from '../lib/sanitize-html';
import type { Post } from '../lib/db/posts';
import { marked } from 'marked';
import { defaultAuthor, defaultSiteName } from '../data/nav';

interface Props { post: Post }
const { post } = Astro.props;

const driver = Astro.locals.db!;
const tenant = Astro.locals.tenant!;
const env_ = env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };

// Fire every independent DB read in parallel -- serial awaits were
// stacking three RTTs to Neon (~50ms each) before render could begin.
// All three queries only need the post + tenant we already have, so
// nothing depends on the previous one's result.
const [bodyResolver, cover, postTags] = await Promise.all([
  buildBodyImageResolver(driver, post, env_),
  coverUrlFor(driver, post, env_),
  tagsRepo.listForPost(driver, { siteId: tenant.id, postId: post.id }),
]);
const rewritten = rewriteImageTokens(post.body, bodyResolver);
// marked.parse() passes raw HTML through. Sanitize before set:html so
// hostile authors can't XSS readers.
const rendered = sanitizePostHtml(await marked.parse(rewritten));
const firstBodyImg = firstBodyImageInfo(post.body, bodyResolver);
const dateStr = post.publishedAt ? post.publishedAt.toISOString().slice(0, 10) : '';
const tagNames = postTags.map((t) => t.name);
const description = post.description ?? firstParagraph(post.body) ?? undefined;

const canonical = `${Astro.url.origin}${Astro.url.pathname}`;
const siteName = tenant.name ?? defaultSiteName;

// BlogPosting JSON-LD enables Google rich results (article cards in
// search). Keep it minimal; only emit fields we actually have.
const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  url: canonical,
  datePublished: post.publishedAt?.toISOString(),
  dateModified: post.updatedAt.toISOString(),
  author: { '@type': 'Person', name: defaultAuthor },
  publisher: { '@type': 'Organization', name: siteName },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};
if (description) jsonLd.description = description;
if (cover) jsonLd.image = cover;
if (tagNames.length) jsonLd.keywords = tagNames.join(', ');
---
<BaseLayout
  title={post.title}
  description={description}
  image={cover ?? undefined}
  type="article"
  publishedAt={post.publishedAt ?? undefined}
  modifiedAt={post.updatedAt}
  tags={tagNames}
  jsonLd={jsonLd}
  lcpImage={firstBodyImg ?? undefined}
>
  <article>
    <section class="title"><h1>{post.title}</h1></section>
    <section class="meta">
      <span class="time">
        <time datetime={dateStr}>{dateStr}</time>
      </span>
      {postTags.length > 0 && (
        <span class="tags">
          {postTags.map((t) => (
            <a href={`/tags/${t.slug}`} rel="tag">#{t.name}</a>
          ))}
        </span>
      )}
    </section>
    <section class="post" set:html={rendered}></section>
  </article>
</BaseLayout>

<script>
  // Lazy-load the lightbox bundle (~20KB + photoswipe) out of the LCP
  // window. The dynamic import() splits into a separate Vite chunk;
  // this outer script is tiny.
  //
  // Two triggers:
  //   1. First user interaction with the article (pointerdown/touchstart)
  //   2. requestIdleCallback after first paint, whichever wins.
  //
  // Re-runs on every Astro view-transition arrival via astro:page-load,
  // so navigating from /post-A to /post-B (no full reload) still binds
  // PhotoSwipe to the new <article>. initLightbox() is idempotent
  // (guards via root.dataset.lightboxInited).
  let bundlePromise: Promise<typeof import('../scripts/lightbox')> | null = null;
  const loadBundle = () => (bundlePromise ??= import('../scripts/lightbox'));
  const init = async () => {
    const m = await loadBundle();
    m.initLightbox();
  };

  const armPage = () => {
    const article = document.querySelector('article .post');
    if (!article) return;
    const events = ['pointerdown', 'touchstart'] as const;
    let armed = true;
    const trigger = () => {
      if (!armed) return;
      armed = false;
      init();
    };
    events.forEach((e) => article.addEventListener(e, trigger, { once: true, passive: true }));
    if ('requestIdleCallback' in window) {
      requestIdleCallback(trigger, { timeout: 3000 });
    } else {
      setTimeout(trigger, 1500);
    }
  };

  armPage();
  document.addEventListener('astro:page-load', armPage);
</script>
