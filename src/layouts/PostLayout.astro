---
import { env } from 'cloudflare:workers';
import BaseLayout from './BaseLayout.astro';
import { coverUrlFor, buildBodyImageResolver, batchCoverImagesFor } from '../lib/render';
import * as tagsRepo from '../lib/db/tags';
import * as postsRepo from '../lib/db/posts';
import { firstParagraph, firstBodyImageInfo, rewriteImageTokens, renderPostHtml } from '../lib/markdown';
import { rewriteEmbeds } from '../lib/embeds';
import { sanitizePostHtml } from '../lib/sanitize-html';
import type { Post } from '../lib/db/posts';
import { postUrl } from '../lib/post-url';
import { defaultAuthor, defaultSiteName } from '../data/nav';
import { resolveCanonicalOrigin, buildPostBreadcrumbJsonLd, asGraph, absoluteUrl } from '../lib/seo';

interface Props { post: Post }
const { post } = Astro.props;

const driver = Astro.locals.db!;
const tenant = Astro.locals.tenant!;
const env_ = env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };

// Fire every independent DB read in parallel -- serial awaits were
// stacking three RTTs to Neon (~50ms each) before render could begin.
// All three queries only need the post + tenant we already have, so
// nothing depends on the previous one's result.
const [bodyResolver, cover, postTags, adjacent, related] = await Promise.all([
  buildBodyImageResolver(driver, post, env_),
  coverUrlFor(driver, post, env_),
  tagsRepo.listForPost(driver, { siteId: tenant.id, postId: post.id }),
  postsRepo.findAdjacent(driver, { siteId: tenant.id, post }),
  postsRepo.findRelatedByTags(driver, { siteId: tenant.id, postId: post.id, limit: 4 }),
]);
const relatedCovers = related.length
  ? await batchCoverImagesFor(driver, tenant.id, related, env_)
  : new Map();
const previousUrl = adjacent.previous?.publishedAt
  ? postUrl({ publishedAt: adjacent.previous.publishedAt, slug: adjacent.previous.slug })
  : null;
const nextUrl = adjacent.next?.publishedAt
  ? postUrl({ publishedAt: adjacent.next.publishedAt, slug: adjacent.next.slug })
  : null;
const rewritten = rewriteEmbeds(rewriteImageTokens(post.body, bodyResolver));
// renderPostHtml shifts body headings down one level so the post title
// remains the page's only H1. Output is sanitized before set:html so a
// hostile author can't XSS readers.
const rendered = sanitizePostHtml(await renderPostHtml(rewritten));
const firstBodyImg = firstBodyImageInfo(post.body, bodyResolver);
const dateStr = post.publishedAt ? post.publishedAt.toISOString().slice(0, 10) : '';
const tagNames = postTags.map((t) => t.name);
const description = post.description ?? firstParagraph(post.body) ?? undefined;

const siteOrigin = resolveCanonicalOrigin(tenant, Astro.url);
const canonical = `${siteOrigin}${Astro.url.pathname}`;
const siteName = tenant.name ?? defaultSiteName;

// BlogPosting JSON-LD enables Google rich results (article cards in
// search). Keep it minimal; only emit fields we actually have.
const blogPosting: Record<string, unknown> = {
  '@type': 'BlogPosting',
  headline: post.title,
  url: canonical,
  datePublished: post.publishedAt?.toISOString(),
  dateModified: post.updatedAt.toISOString(),
  author: { '@type': 'Person', '@id': `${siteOrigin}#author`, name: defaultAuthor },
  publisher: { '@type': 'Organization', name: siteName },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};
if (description) blogPosting.description = description;
// Schema.org requires absolute URLs for ImageObject / image fields --
// Google silently drops the property otherwise, losing the cover's
// surface in image-search results.
if (cover) blogPosting.image = absoluteUrl(cover, siteOrigin);
if (tagNames.length) blogPosting.keywords = tagNames.join(', ');

// BreadcrumbList: surfaces a clickable Home › Year › Title trail in
// mobile SERP results (replaces the URL in the snippet, lifts CTR).
const breadcrumb = buildPostBreadcrumbJsonLd({
  siteUrl: siteOrigin,
  year: post.publishedAt ? String(post.publishedAt.getUTCFullYear()) : 'archive',
  postTitle: post.title,
  postUrl: canonical,
});

const jsonLd = asGraph([blogPosting, breadcrumb]);
---
<BaseLayout
  title={post.title}
  description={description}
  image={cover ?? undefined}
  type="article"
  publishedAt={post.publishedAt ?? undefined}
  modifiedAt={post.updatedAt}
  tags={tagNames}
  jsonLd={jsonLd}
  lcpImage={firstBodyImg ?? undefined}
>
  <article>
    {/* Visible breadcrumbs mirror the BreadcrumbList JSON-LD above.
        Tiny font, muted color so the post title still owns the eye --
        the trail is here for crawlers, screen readers, and the rare
        reader who wants a way back up the date tree. */}
    {post.publishedAt && (
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">{siteName}</a>
        <span aria-hidden="true">›</span>
        <a href={`/archive#${post.publishedAt.getUTCFullYear()}`}>{post.publishedAt.getUTCFullYear()}</a>
        <span aria-hidden="true">›</span>
        <span class="breadcrumb-current">{post.title}</span>
      </nav>
    )}
    <section class="title"><h1>{post.title}</h1></section>
    <section class="meta">
      <span class="time">
        <time datetime={dateStr}>{dateStr}</time>
      </span>
      {postTags.length > 0 && (
        <span class="tags">
          {postTags.map((t) => (
            <a href={`/tags/${t.slug}`} rel="tag">#{t.name}</a>
          ))}
        </span>
      )}
    </section>
    <section class="post" set:html={rendered}></section>

    {/* Chevron strip closing the post: prev (older) on the left, next
        (newer) on the right. Inline SVGs match the header's icon set
        and avoid pulling in Font Awesome just for two glyphs. Renders
        a hollow disc when there's no neighbor in that direction. */}
    <nav class="divider" aria-label="adjacent posts">
      <span>
        {previousUrl && adjacent.previous ? (
          <a href={previousUrl} title={adjacent.previous.title} rel="prev" aria-label={`Older post: ${adjacent.previous.title}`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </a>
        ) : (
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
          </svg>
        )}
      </span>
      <span>
        {nextUrl && adjacent.next ? (
          <a href={nextUrl} title={adjacent.next.title} rel="next" aria-label={`Newer post: ${adjacent.next.title}`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        ) : (
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
          </svg>
        )}
      </span>
    </nav>

    {/* Related posts: up to 4 published siblings ranked by tag overlap.
        Lives below the adjacent chevrons so the eye finishes the post,
        sees its temporal neighbors, and then gets thematic options.
        Each card adds an internal link with topical context for crawlers
        and an engagement path for readers. Hidden entirely when there
        are no related posts (drafts-only sibling set, etc.). */}
    {related.length > 0 && (
      <aside class="related" aria-labelledby="related-heading">
        <h2 id="related-heading" class="related-title">Related</h2>
        <ul class="related-list">
          {related.map((r) => {
            const cov = relatedCovers.get(r.id);
            const href = r.publishedAt ? postUrl({ publishedAt: r.publishedAt, slug: r.slug }) : '#';
            return (
              <li class="related-item">
                <a href={href}>
                  {cov?.url && <img src={cov.url} alt={r.title} loading="lazy" decoding="async" />}
                  <span class="related-item-title">{r.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </aside>
    )}
  </article>
</BaseLayout>

<script>
  // Lazy-load the lightbox bundle (~20KB + photoswipe) out of the LCP
  // window. The dynamic import() splits into a separate Vite chunk;
  // this outer script is tiny.
  //
  // Two triggers:
  //   1. First user interaction with the article (pointerdown/touchstart)
  //   2. requestIdleCallback after first paint, whichever wins.
  //
  // Re-runs on every Astro view-transition arrival via astro:page-load,
  // so navigating from /post-A to /post-B (no full reload) still binds
  // PhotoSwipe to the new <article>. initLightbox() is idempotent
  // (guards via root.dataset.lightboxInited).
  let bundlePromise: Promise<typeof import('../scripts/lightbox')> | null = null;
  const loadBundle = () => (bundlePromise ??= import('../scripts/lightbox'));
  const init = async () => {
    const m = await loadBundle();
    m.initLightbox();
  };

  const armPage = () => {
    const article = document.querySelector('article .post');
    if (!article) return;
    const events = ['pointerdown', 'touchstart'] as const;
    let armed = true;
    const trigger = () => {
      if (!armed) return;
      armed = false;
      init();
    };
    events.forEach((e) => article.addEventListener(e, trigger, { once: true, passive: true }));
    if ('requestIdleCallback' in window) {
      requestIdleCallback(trigger, { timeout: 3000 });
    } else {
      setTimeout(trigger, 1500);
    }
  };

  armPage();
  document.addEventListener('astro:page-load', armPage);
</script>
