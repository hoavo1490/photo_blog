---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { adjacentPosts } from '../utils/adjacent';
import { byDateDesc } from '../utils/tags';
import { postUrl } from '../utils/post-url';
import { allImages } from '../utils/extract';
import type { CollectionEntry } from 'astro:content';

interface Props { post: CollectionEntry<'posts'> }
const { post } = Astro.props;

const all = await getCollection('posts');
const { previous, next } = adjacentPosts(all, post);
const dateStr = post.data.date.toISOString().slice(0, 10);

// Build the cross-post lightbox stream: every image across every post,
// in newest-first chronological order. The browser uses this to let
// the lightbox swipe through the entire blog as one continuous gallery.
type StreamItem = { src: string; href: string; title: string };
const stream: StreamItem[] = [];
for (const p of all.sort(byDateDesc)) {
  const href = postUrl(p);
  for (const src of allImages(p.body ?? '')) {
    stream.push({ src, href, title: p.data.title });
  }
}
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    <section class="title">
      <h2>{post.data.title}</h2>
    </section>
    <section class="meta">
      <span class="time">
        <time datetime={dateStr}>{dateStr}</time>
      </span>
      {post.data.tags.length > 0 && (
        <span class="tags">
          {post.data.tags.map((tag) => (
            <a href={`/tags.html#${encodeURIComponent(tag)}`} title={tag}>#{tag}</a>
          ))}
        </span>
      )}
    </section>
    <section class="post">
      <slot />
    </section>
    <div class="divider">
      <span>
        {previous
          ? <a href={previous.url} title={previous.title}><i class="fa fa-chevron-left"></i></a>
          : <i class="fa fa-circle"></i>}
      </span>
      <span>
        {next
          ? <a href={next.url} title={next.title}><i class="fa fa-chevron-right"></i></a>
          : <i class="fa fa-circle"></i>}
      </span>
    </div>
  </article>
</BaseLayout>

<script id="lightbox-stream" type="application/json" set:html={JSON.stringify(stream)}></script>
<script>
  import '../scripts/lightbox';
</script>
