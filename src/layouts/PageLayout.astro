---
import BaseLayout from './BaseLayout.astro';

interface Props { title: string; description?: string; noindex?: boolean }
const { title, description, noindex } = Astro.props;
---
<BaseLayout title={title} description={description} noindex={noindex}>
  <article>
    <section class="title"><h1>{title}</h1></section>
    <section class="post"><slot /></section>
  </article>
</BaseLayout>
