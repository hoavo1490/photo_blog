---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { defaultSiteName, defaultAuthor } from '../data/nav';
import { resolveCanonicalUrl, resolveCanonicalOrigin, absoluteUrl, absolutizeSrcset } from '../lib/seo';
import '../styles/global.scss';

// SEO meta is centralized here so per-page props translate cleanly into
// title, description, canonical, Open Graph, Twitter, and (optionally)
// JSON-LD. Image URLs must be absolute -- crawlers don't resolve
// relative URLs in og:image / twitter:image.

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  type?: 'website' | 'article';
  publishedAt?: Date;
  modifiedAt?: Date;
  tags?: string[];
  noindex?: boolean;
  jsonLd?: unknown;
  /** When set, emit <link rel="preload" as="image"> with srcset/sizes
   *  so the browser starts fetching the LCP image during head parsing
   *  instead of after body discovery. Pass src + srcset + sizes that
   *  exactly match the <img>/<source> on the page for the picked
   *  variant to be the same. `webpSrcset` adds a parallel preload for
   *  the WebP track; browsers honor the one matching their accepted
   *  media types. */
  lcpImage?: { src: string; srcset?: string; sizes?: string; webpSrcset?: string; avifSrcset?: string };
}

const {
  title,
  description,
  image,
  imageWidth,
  imageHeight,
  type = 'website',
  publishedAt,
  modifiedAt,
  tags,
  noindex = false,
  jsonLd,
  lcpImage,
} = Astro.props;

const siteName = Astro.locals.tenant?.name ?? defaultSiteName;
const pageTitle = title ? `${title} — ${siteName}` : siteName;
const fallbackDescription = 'Photo journal by Rio.';
const desc = description ?? fallbackDescription;

// Canonical pins to the tenant's customDomain when set, so workers.dev
// preview traffic doesn't end up indexed alongside the production
// hostname. Falls back to the request origin for tenants without a
// custom domain yet.
const canonical = resolveCanonicalUrl(Astro.locals.tenant ?? null, Astro.url);
const canonicalOrigin = resolveCanonicalOrigin(Astro.locals.tenant ?? null, Astro.url);
// og:image, twitter:image, and the LCP preload must be absolute URLs
// -- crawlers and feed readers don't resolve relative paths reliably,
// and Google's structured-data parser drops images with relative URLs.
const absImage = image ? absoluteUrl(image, canonicalOrigin) : undefined;
const absLcpImage = lcpImage ? {
  ...lcpImage,
  src: absoluteUrl(lcpImage.src, canonicalOrigin),
  srcset: absolutizeSrcset(lcpImage.srcset, canonicalOrigin),
  webpSrcset: absolutizeSrcset(lcpImage.webpSrcset, canonicalOrigin),
  avifSrcset: absolutizeSrcset(lcpImage.avifSrcset, canonicalOrigin),
} : undefined;
---
<!DOCTYPE html>
<html lang="vi">
  <head>
    {/* SPA-style navigation between pages on this site. Astro handles
        head merging, scroll restoration, and re-firing astro:page-load
        on every arrival. Browsers without the View Transitions API
        fall back to standard full-page navigation -- no breakage. */}
    <ClientRouter />
    <meta charset="utf-8" />
    <meta name="author" content={defaultAuthor} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {/* Skip canonical on noindex pages (404, etc) -- emitting a canonical
        for a missing URL tells Google "yes, the broken URL is the
        canonical one," which is the opposite of what we want. */}
    {!noindex && <link rel="canonical" href={canonical} />}

    {/* Open Graph */}
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title ?? siteName} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="vi_VN" />
    {absImage && <meta property="og:image" content={absImage} />}
    {image && imageWidth && <meta property="og:image:width" content={String(imageWidth)} />}
    {image && imageHeight && <meta property="og:image:height" content={String(imageHeight)} />}
    {type === 'article' && publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    {type === 'article' && modifiedAt && (
      <meta property="article:modified_time" content={modifiedAt.toISOString()} />
    )}
    {type === 'article' && tags?.map((t) => (
      <meta property="article:tag" content={t} />
    ))}

    {/* Twitter Card */}
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title ?? siteName} />
    <meta name="twitter:description" content={desc} />
    {absImage && <meta name="twitter:image" content={absImage} />}

    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/atom.xml" />

    {/* LCP preload: ONE preload, matching what the modal browser will
        pick. Modern browsers that support AVIF also support WebP, so
        emitting both made them download both -- ~95KB of dead weight
        in the LCP window. Pick the smallest format we have; older
        browsers without that format don't preload but still render
        correctly via the <picture> chain in the body. */}
    {absLcpImage && absLcpImage.avifSrcset && (
      <link
        rel="preload"
        as="image"
        type="image/avif"
        imagesrcset={absLcpImage.avifSrcset}
        imagesizes={absLcpImage.sizes}
        fetchpriority="high"
      />
    )}
    {absLcpImage && !absLcpImage.avifSrcset && absLcpImage.webpSrcset && (
      <link
        rel="preload"
        as="image"
        type="image/webp"
        imagesrcset={absLcpImage.webpSrcset}
        imagesizes={absLcpImage.sizes}
        fetchpriority="high"
      />
    )}
    {absLcpImage && !absLcpImage.webpSrcset && !absLcpImage.avifSrcset && (
      <link
        rel="preload"
        as="image"
        href={absLcpImage.src}
        imagesrcset={absLcpImage.srcset}
        imagesizes={absLcpImage.sizes}
        fetchpriority="high"
      />
    )}
    {/* Self-hosted Be Vietnam Pro Light. Designed by a Vietnamese type
        designer (Lâm Bảo Khánh) with proper stacked-diacritic handling
        (ề / ầ / ố / ợ etc.) -- Ubuntu's Latin-only subset was forcing
        the browser to fall back to the system font for every tone
        mark, which looked jarring against Ubuntu's Latin. Two subsets:
        Latin (~13KB) for headers/UI, Vietnamese (~5KB) for tone-marked
        characters. Browsers download only what they need via the
        unicode-range hint, and we preload both so the LCP window
        doesn't flash a fallback font for either alphabet. */}
    <link rel="preload" href="/fonts/be-vietnam-pro-300-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/be-vietnam-pro-300-vietnamese.woff2" as="font" type="font/woff2" crossorigin />
    <style is:inline>
      @font-face {
        font-family: 'Be Vietnam Pro';
        font-style: normal;
        font-weight: 300;
        font-display: swap;
        src: url('/fonts/be-vietnam-pro-300-vietnamese.woff2') format('woff2');
        unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;
      }
      @font-face {
        font-family: 'Be Vietnam Pro';
        font-style: normal;
        font-weight: 300;
        font-display: swap;
        src: url('/fonts/be-vietnam-pro-300-latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }
    </style>

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <div id="main" role="main">
      <Header />
      <div id="content">
        <slot />
      </div>
      <Footer />
    </div>
  </body>
</html>
