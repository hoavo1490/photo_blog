---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { defaultSiteName, defaultAuthor } from '../data/nav';
import '../styles/global.scss';

// SEO meta is centralized here so per-page props translate cleanly into
// title, description, canonical, Open Graph, Twitter, and (optionally)
// JSON-LD. Image URLs must be absolute -- crawlers don't resolve
// relative URLs in og:image / twitter:image.

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  type?: 'website' | 'article';
  publishedAt?: Date;
  modifiedAt?: Date;
  tags?: string[];
  noindex?: boolean;
  jsonLd?: unknown;
  /** When set, emit <link rel="preload" as="image"> with srcset/sizes
   *  so the browser starts fetching the LCP image during head parsing
   *  instead of after body discovery. Pass src + srcset + sizes that
   *  exactly match the <img>/<source> on the page for the picked
   *  variant to be the same. `webpSrcset` adds a parallel preload for
   *  the WebP track; browsers honor the one matching their accepted
   *  media types. */
  lcpImage?: { src: string; srcset?: string; sizes?: string; webpSrcset?: string; avifSrcset?: string };
}

const {
  title,
  description,
  image,
  imageWidth,
  imageHeight,
  type = 'website',
  publishedAt,
  modifiedAt,
  tags,
  noindex = false,
  jsonLd,
  lcpImage,
} = Astro.props;

const siteName = Astro.locals.tenant?.name ?? defaultSiteName;
const pageTitle = title ? `${title} — ${siteName}` : siteName;
const fallbackDescription = 'Photo journal by Rio.';
const desc = description ?? fallbackDescription;

// Canonical = origin + pathname (no query string). Tracks the actually
// served host so workers.dev and the eventual custom domain each get a
// truthful canonical without lying to crawlers.
const canonical = `${Astro.url.origin}${Astro.url.pathname}`;
---
<!DOCTYPE html>
<html lang="vi">
  <head>
    {/* SPA-style navigation between pages on this site. Astro handles
        head merging, scroll restoration, and re-firing astro:page-load
        on every arrival. Browsers without the View Transitions API
        fall back to standard full-page navigation -- no breakage. */}
    <ClientRouter />
    <meta charset="utf-8" />
    <meta name="author" content={defaultAuthor} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {/* Skip canonical on noindex pages (404, etc) -- emitting a canonical
        for a missing URL tells Google "yes, the broken URL is the
        canonical one," which is the opposite of what we want. */}
    {!noindex && <link rel="canonical" href={canonical} />}

    {/* Open Graph */}
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title ?? siteName} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="vi_VN" />
    {image && <meta property="og:image" content={image} />}
    {image && imageWidth && <meta property="og:image:width" content={String(imageWidth)} />}
    {image && imageHeight && <meta property="og:image:height" content={String(imageHeight)} />}
    {type === 'article' && publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    {type === 'article' && modifiedAt && (
      <meta property="article:modified_time" content={modifiedAt.toISOString()} />
    )}
    {type === 'article' && tags?.map((t) => (
      <meta property="article:tag" content={t} />
    ))}

    {/* Twitter Card */}
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title ?? siteName} />
    <meta name="twitter:description" content={desc} />
    {image && <meta name="twitter:image" content={image} />}

    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/atom.xml" />

    {/* LCP preload: ONE preload, matching what the modal browser will
        pick. Modern browsers that support AVIF also support WebP, so
        emitting both made them download both -- ~95KB of dead weight
        in the LCP window. Pick the smallest format we have; older
        browsers without that format don't preload but still render
        correctly via the <picture> chain in the body. */}
    {lcpImage && lcpImage.avifSrcset && (
      <link
        rel="preload"
        as="image"
        type="image/avif"
        imagesrcset={lcpImage.avifSrcset}
        imagesizes={lcpImage.sizes}
        fetchpriority="high"
      />
    )}
    {lcpImage && !lcpImage.avifSrcset && lcpImage.webpSrcset && (
      <link
        rel="preload"
        as="image"
        type="image/webp"
        imagesrcset={lcpImage.webpSrcset}
        imagesizes={lcpImage.sizes}
        fetchpriority="high"
      />
    )}
    {lcpImage && !lcpImage.webpSrcset && !lcpImage.avifSrcset && (
      <link
        rel="preload"
        as="image"
        href={lcpImage.src}
        imagesrcset={lcpImage.srcset}
        imagesizes={lcpImage.sizes}
        fetchpriority="high"
      />
    )}
    {/* Self-hosted Ubuntu Light. Same-origin avoids the cross-domain
        DNS/TCP/TLS round-trip and a render-blocking CSS request to
        googleapis.com. Preload + inline @font-face so the font starts
        downloading during head parse but text still renders in the
        fallback first via font-display: swap. */}
    <link rel="preload" href="/fonts/ubuntu-300.woff2" as="font" type="font/woff2" crossorigin />
    <style is:inline>
      @font-face {
        font-family: 'Ubuntu';
        font-style: normal;
        font-weight: 300;
        font-display: swap;
        src: url('/fonts/ubuntu-300.woff2') format('woff2');
      }
    </style>

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <div id="main" role="main">
      <Header />
      <div id="content">
        <slot />
      </div>
      <Footer />
    </div>
  </body>
</html>
