---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { defaultSiteName, defaultAuthor } from '../data/nav';
import '../styles/global.scss';

// SEO meta is centralized here so per-page props translate cleanly into
// title, description, canonical, Open Graph, Twitter, and (optionally)
// JSON-LD. Image URLs must be absolute -- crawlers don't resolve
// relative URLs in og:image / twitter:image.

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  type?: 'website' | 'article';
  publishedAt?: Date;
  modifiedAt?: Date;
  tags?: string[];
  noindex?: boolean;
  jsonLd?: unknown;
  /** When set, emit <link rel="preload" as="image"> with srcset/sizes
   *  so the browser starts fetching the LCP image during head parsing
   *  instead of after body discovery. Pass src + srcset + sizes that
   *  exactly match the <img>/<source> on the page for the picked
   *  variant to be the same. `webpSrcset` adds a parallel preload for
   *  the WebP track; browsers honor the one matching their accepted
   *  media types. */
  lcpImage?: { src: string; srcset?: string; sizes?: string; webpSrcset?: string };
}

const {
  title,
  description,
  image,
  imageWidth,
  imageHeight,
  type = 'website',
  publishedAt,
  modifiedAt,
  tags,
  noindex = false,
  jsonLd,
  lcpImage,
} = Astro.props;

const siteName = Astro.locals.tenant?.name ?? defaultSiteName;
const pageTitle = title ? `${title} — ${siteName}` : siteName;
const fallbackDescription = 'Photo journal by Rio.';
const desc = description ?? fallbackDescription;

// Canonical = origin + pathname (no query string). Tracks the actually
// served host so workers.dev and the eventual custom domain each get a
// truthful canonical without lying to crawlers.
const canonical = `${Astro.url.origin}${Astro.url.pathname}`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="author" content={defaultAuthor} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    {/* Open Graph */}
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title ?? siteName} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    {image && <meta property="og:image" content={image} />}
    {image && imageWidth && <meta property="og:image:width" content={String(imageWidth)} />}
    {image && imageHeight && <meta property="og:image:height" content={String(imageHeight)} />}
    {type === 'article' && publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    {type === 'article' && modifiedAt && (
      <meta property="article:modified_time" content={modifiedAt.toISOString()} />
    )}
    {type === 'article' && tags?.map((t) => (
      <meta property="article:tag" content={t} />
    ))}

    {/* Twitter Card */}
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title ?? siteName} />
    <meta name="twitter:description" content={desc} />
    {image && <meta name="twitter:image" content={image} />}

    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/atom.xml" />

    {/* LCP preload: start fetching the largest contentful image during
        head parsing instead of after the body is discovered. Browsers
        match the picked variant against srcset/sizes -- these MUST be
        identical to what the <img> ultimately renders, or the preload
        gets discarded and counts as wasted bytes. */}
    {/* Single LCP preload. When a webp track exists, use type="image/webp"
        so non-WebP browsers (~5%) skip it and fall through to the
        <picture>'s JPEG <img>. Emitting both was downloading the LCP
        image twice (webp + jpg) on every modern browser. */}
    {lcpImage && lcpImage.webpSrcset && (
      <link
        rel="preload"
        as="image"
        type="image/webp"
        imagesrcset={lcpImage.webpSrcset}
        imagesizes={lcpImage.sizes}
        fetchpriority="high"
      />
    )}
    {lcpImage && !lcpImage.webpSrcset && (
      <link
        rel="preload"
        as="image"
        href={lcpImage.src}
        imagesrcset={lcpImage.srcset}
        imagesizes={lcpImage.sizes}
        fetchpriority="high"
      />
    )}
    {/* Google Fonts: preconnect + async CSS load. The media-print swap
        makes the <link> non-blocking; the noscript fallback keeps it
        working for users with JS disabled. display=swap renders text in
        the fallback font until Ubuntu is ready. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css?family=Ubuntu:300&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Ubuntu:300&display=swap" />
    </noscript>

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <div id="main" role="main">
      <Header />
      <div id="content">
        <slot />
      </div>
      <Footer />
    </div>
  </body>
</html>
