---
import type { Album } from '~/lib/db/albums';

interface Props {
  album: Album;
  coverUrl: string | null;
}
const { album, coverUrl } = Astro.props;
---
<a href={`/gallery/${album.slug}`} class="album-card">
  <div class="album-cover">
    {coverUrl ? (
      <img src={coverUrl} alt={album.title} loading="lazy" />
    ) : (
      <div class="album-cover-placeholder" />
    )}
  </div>
  <div class="album-info">
    <h2 class="album-title">{album.title}</h2>
    {album.description && <p class="album-desc">{album.description}</p>}
  </div>
</a>

<style>
.album-card {
  display: block;
  text-decoration: none;
  color: inherit;
}
.album-cover {
  aspect-ratio: 4/3;
  overflow: hidden;
  background: #f0f0f0;
}
.album-cover img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}
.album-card:hover .album-cover img {
  transform: scale(1.03);
}
.album-cover-placeholder {
  width: 100%;
  height: 100%;
  background: #e8e8e8;
}
.album-info {
  padding: 10px 0 6px;
}
.album-title {
  font-size: 1em;
  font-weight: 600;
  color: #333;
  margin: 0;
}
.album-desc {
  font-size: 0.85em;
  color: #777;
  margin: 3px 0 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
</style>
