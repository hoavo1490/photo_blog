---
import { postUrl } from '../lib/post-url';
import type { Post } from '../lib/db/posts';
import { variantUrlForKey } from '../lib/r2/images';

interface Props {
  post: Post;
  cover: string;
  description?: string | null;
  /** True for the first above-the-fold card -- emits loading=eager and
   *  fetchpriority=high so the LCP image starts loading immediately
   *  instead of waiting behind lazy-load heuristics. */
  priority?: boolean;
  /** True for non-LCP cards that are nonetheless above the fold (cards
   *  2-5 on most layouts). Eager-load them so they paint with the page
   *  instead of "popping in" via Chrome's lazy heuristic, but leave
   *  fetchpriority at auto so they yield bandwidth to the LCP fetch. */
  aboveFold?: boolean;
  /** Variant widths available for this cover image, e.g. [400,800,1200].
   *  When empty the renderer falls back to a plain <img src>. */
  variantWidths?: number[];
  /** Original key, needed to derive variant URLs. Only used when
   *  variantWidths is non-empty. */
  r2Key?: string;
  /** R2 origin env so we can resolve variant URLs. */
  r2Env?: { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };
  /** True when matching `.<W>w.avif` variants exist alongside JPEG/WebP. */
  hasAvif?: boolean;
}
const { post, cover, description, priority = false, aboveFold = false, variantWidths = [], r2Key, r2Env, hasAvif = false } = Astro.props;

// Three loading strategies:
//   priority (LCP):     eager, sync decode, fetchpriority=high
//   aboveFold (rank 1+): eager, async decode, fetchpriority=auto
//   below the fold:     lazy,  async decode, fetchpriority=low
const loadingAttr  = priority ? 'eager' : aboveFold ? 'eager' : 'lazy';
const decodingAttr = priority ? 'sync'  : 'async';
const fetchAttr   = priority ? 'high'  : aboveFold ? 'auto'  : 'low';

// Sizes attribute matches the homepage grid AND the page-width mixin
// in styles/global.scss (#content caps at 300/350/400/750px below
// 320/375/414/800px breakpoints). The container is never 100vw, so
// promising 100vw made Lighthouse pick the 800w variant when the
// 400w one would do at DPR 1 -- ~90KB of wasted LCP bytes.
//
//   <= 480px : 1 column inside a 400px container → 400px
//   <= 800px : 2 columns inside a ~400px container → ~200px
//   else     : 3 columns inside a 750px container with 12px of gaps → ~246px
const sizesAttr = '(max-width: 480px) 400px, (max-width: 800px) 200px, 250px';

const jpegSrcset: string[] = [];
const webpSrcset: string[] = [];
const avifSrcset: string[] = [];
if (r2Key && r2Env && variantWidths.length > 0) {
  for (const w of variantWidths) {
    const jpeg = variantUrlForKey(r2Key, w, r2Env);
    jpegSrcset.push(`${jpeg} ${w}w`);
    webpSrcset.push(`${jpeg.replace(/\.jpg$/, '.webp')} ${w}w`);
    if (hasAvif) avifSrcset.push(`${jpeg.replace(/\.jpg$/, '.avif')} ${w}w`);
  }
  jpegSrcset.push(`${cover} 1600w`);
}
const jpegSrcsetStr = jpegSrcset.length > 0 ? jpegSrcset.join(', ') : undefined;
const webpSrcsetStr = webpSrcset.length > 0 ? webpSrcset.join(', ') : undefined;
const avifSrcsetStr = avifSrcset.length > 0 ? avifSrcset.join(', ') : undefined;
---
<a class="card" href={postUrl({ publishedAt: post.publishedAt!, slug: post.slug })}>
  {webpSrcsetStr ? (
    <picture>
      {avifSrcsetStr && <source type="image/avif" srcset={avifSrcsetStr} sizes={sizesAttr} />}
      <source type="image/webp" srcset={webpSrcsetStr} sizes={sizesAttr} />
      <img
        src={cover}
        srcset={jpegSrcsetStr}
        sizes={jpegSrcsetStr ? sizesAttr : undefined}
        alt={post.title}
        loading={loadingAttr}
        decoding={decodingAttr}
        fetchpriority={fetchAttr}
      />
    </picture>
  ) : (
    <img
      src={cover}
      srcset={jpegSrcsetStr}
      sizes={jpegSrcsetStr ? sizesAttr : undefined}
      alt={post.title}
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? 'sync' : 'async'}
      fetchpriority={priority ? 'high' : 'auto'}
    />
  )}
  <div class="overlay">
    <div class="title">{post.title}</div>
    <div class="desc">{description ?? post.description ?? ''}</div>
  </div>
</a>
