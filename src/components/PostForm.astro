---
import type { Post } from '../lib/db/posts';
import { formatDateChip, formatTagsChip } from '../scripts/post-meta-chips';

interface Props {
  mode: 'new' | 'edit';
  siteId: string;
  initial: Partial<Post> & {
    tagNames?: string[];
    coverUrl?: string | null;
    /** {uuid, url} for every image:<uuid> token in the body, resolved
     *  server-side so the editor can render images inline. New uploads
     *  during the session join this map client-side. */
    bodyImages?: ReadonlyArray<{ id: string; url: string }>;
  };
}
const { mode, siteId, initial } = Astro.props;
const today = new Date().toISOString().slice(0, 10);
const initialCoverId = initial.coverImageId ?? '';
const initialCoverUrl = initial.coverUrl ?? '';
const initialBodyImages = initial.bodyImages ?? [];
const initialDate = initial.publishedAt
  ? initial.publishedAt.toISOString().slice(0, 10)
  : today;
const initialTagNames = initial.tagNames ?? [];
const initialTagsCsv = initialTagNames.join(', ');
const dateChipText = formatDateChip(initialDate, today);
const tagsChipText = formatTagsChip(initialTagNames);
---
<form
  id="post-form"
  data-mode={mode}
  data-site-id={siteId}
  data-post-id={initial.id ?? ''}
  data-today={today}
  data-body-images={JSON.stringify(initialBodyImages)}
>
  {/* ─── editor header: close · title · publish ─────────────────────── */}
  <header class="editor-header">
    <button type="button" class="icon-btn close-btn" onclick="history.back()" aria-label="close">✕</button>
    <input
      name="title"
      class="title-input"
      required
      value={initial.title ?? ''}
      placeholder="Title…"
      autocomplete="off"
    />
    <button type="submit" class="primary publish-btn" id="save-btn">
      {mode === 'edit' ? 'Save' : 'Publish'}
    </button>
  </header>

  {/* ─── status row: date · tags · cover · more ────────────────────── */}
  <div class="status-row">
    <button type="button" class="chip" data-sheet="date" id="chip-date">
      <span class="chip-text">{dateChipText}</span>
    </button>
    <span class="chip-sep" aria-hidden="true">·</span>
    <button type="button" class="chip" data-sheet="tags" id="chip-tags">
      <span class="chip-text">{tagsChipText}</span>
    </button>
    <span class="chip-sep" aria-hidden="true">·</span>
    <button type="button" class="chip chip-cover" data-sheet="cover" id="chip-cover" data-has-cover={initialCoverUrl ? 'true' : 'false'}>
      {initialCoverUrl && (
        <img class="chip-thumb" src={initialCoverUrl} alt="" id="chip-cover-thumb" />
      )}
      <span class="chip-text" id="chip-cover-text">{initialCoverUrl ? 'cover' : '+ cover'}</span>
    </button>
    <span class="chip-sep" aria-hidden="true">·</span>
    <button type="button" class="chip chip-more" data-sheet="more" id="chip-more">
      <span class="chip-text">more</span>
    </button>
  </div>

  {/* Hidden inputs for the values the chips display. The form serializes
      these into the save payload via FormData. */}
  <input type="hidden" name="date" id="date-input" value={initialDate} />
  <input type="hidden" name="tags" id="tags-input" value={initialTagsCsv} />
  <input type="hidden" name="slug" id="slug-input" value={initial.slug ?? ''} />
  <input type="hidden" name="coverImageId" id="cover-image-id" value={initialCoverId} />

  {/* ─── inline sheets: one shows at a time, below the status row ─── */}
  <div class="meta-sheet" id="sheet-date" hidden>
    <label class="sheet-row">
      <span class="sheet-label">date</span>
      <input type="date" id="date-picker" value={initialDate} />
    </label>
  </div>

  <div class="meta-sheet" id="sheet-tags" hidden>
    <label class="sheet-row">
      <span class="sheet-label">tags (comma-separated)</span>
      <input type="text" id="tags-editor" value={initialTagsCsv} placeholder="photography, leica" />
    </label>
  </div>

  <div class="meta-sheet" id="sheet-cover" hidden>
    <div class="sheet-row sheet-row-cover">
      <div id="cover-thumb-wrap" style={initialCoverUrl ? '' : 'display:none;'}>
        <img id="cover-thumb" src={initialCoverUrl} alt="cover" />
        <button type="button" id="cover-remove" class="cover-remove-btn" aria-label="remove cover">×</button>
      </div>
      <label class="cover-upload-btn">
        <span id="cover-upload-text">{initialCoverUrl ? 'replace' : '+ choose cover'}</span>
        <input id="cover-picker" type="file" accept="image/*" style="display:none;" />
      </label>
      <span class="upload-status" id="cover-status"></span>
    </div>
  </div>

  <div class="meta-sheet" id="sheet-more" hidden>
    <label class="sheet-row">
      <span class="sheet-label">slug (auto from title if blank)</span>
      <input type="text" id="slug-editor" value={initial.slug ?? ''} placeholder="leica-summicron-50mm" />
    </label>
    {mode === 'edit' && (
      <div class="sheet-row">
        <button type="button" class="danger" id="delete-btn">delete this post</button>
      </div>
    )}
  </div>

  {/* ─── body editor: Milkdown mounts here, textarea is the fallback ─ */}
  <div id="milkdown-editor" class="milkdown-host"></div>
  <textarea id="body-area" name="body" rows="14" placeholder="write here…" hidden>{initial.body ?? ''}</textarea>

  <div id="preview-area" class="preview-area" hidden>
    <div class="preview-placeholder">nothing to preview yet…</div>
  </div>

  {/* ─── sticky bottom toolbar ─────────────────────────────────────── */}
  <div class="bottom-toolbar" id="bottom-toolbar">
    <button type="button" class="tb" data-cmd="bold" title="bold"><strong>B</strong></button>
    <button type="button" class="tb" data-cmd="italic" title="italic"><em>I</em></button>
    <button type="button" class="tb" data-cmd="blockquote" title="quote">❝</button>
    <button type="button" class="tb" data-cmd="list" title="list">•</button>
    <button type="button" class="tb" data-cmd="link" title="link">🔗</button>
    <label class="tb tb-image" title="insert image" aria-label="insert image">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="1.5" y="3" width="15" height="12" rx="1.5"/>
        <polyline points="1.5,12 5.5,8 8.5,11 11.5,8.5 16.5,12"/>
        <circle cx="13" cy="6.5" r="1.25"/>
      </svg>
      <input id="image-picker" type="file" accept="image/*" multiple style="display:none;" />
    </label>
    <div class="upload-progress" id="upload-progress" hidden>
      <div class="upload-progress-bar" id="upload-progress-bar"></div>
    </div>
    <span class="tb-spacer"></span>
    <button type="button" class="tb tb-preview" data-cmd="preview" id="preview-toggle" title="Toggle preview" aria-label="Toggle preview" aria-pressed="false">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z"/>
        <circle cx="8" cy="8" r="2"/>
      </svg>
      <span class="tb-label">Preview</span>
    </button>
  </div>
</form>

<style lang="scss">
@use "../styles/post-content" as *;

  /* Editor layout: full-viewport flex column. The Crepe body editor
     takes the middle, the sticky header + status row stack at the top,
     and the bottom toolbar docks at the bottom. */
  #post-form {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    background: var(--bg);
    color: var(--fg);
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', Roboto, sans-serif;
  }

  /* ─── Header: close · title · save ────────────────────────────── */
  .editor-header {
    display: flex; align-items: center; gap: 12px;
    padding: calc(var(--safe-top) + 12px) 20px 12px;
    background: var(--bg-elev);
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 5;
  }
  .icon-btn {
    width: 40px; height: 40px; min-height: 0; padding: 0;
    border: none; background: transparent;
    font-size: 18px; line-height: 1;
    color: var(--muted); border-radius: 8px;
    cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background-color 180ms ease, color 180ms ease;
  }
  .icon-btn:hover { background: var(--bg-sunken); color: var(--fg); }
  .icon-btn:focus-visible { outline: 2px solid var(--fg); outline-offset: 2px; }
  .title-input {
    flex: 1; min-width: 0;
    padding: 8px 10px;
    font: inherit;
    font-size: 22px; font-weight: 600; letter-spacing: -0.01em;
    line-height: 1.3;
    border: none; background: transparent;
    border-radius: 6px;
    color: var(--fg);
  }
  .title-input::placeholder { color: var(--muted-2); font-weight: 500; }
  .title-input:focus { outline: none; background: var(--bg-sunken); }
  .publish-btn {
    min-height: 0; height: 36px; padding: 6px 18px;
    font-size: 14px; font-weight: 600;
    border-radius: 999px;
    background: var(--accent); color: var(--accent-fg);
    border: 1px solid var(--accent);
    cursor: pointer;
    transition: background-color 180ms ease, opacity 180ms ease;
  }
  .publish-btn:hover { background: #27272a; }
  .publish-btn:focus-visible { outline: 2px solid var(--fg); outline-offset: 2px; }
  .publish-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ─── Status row: chips separated by middots ──────────────────── */
  .status-row {
    display: flex; align-items: center; flex-wrap: wrap; gap: 0;
    padding: 10px 20px;
    background: var(--bg-elev);
    border-bottom: 1px solid var(--border);
    font-size: 13px;
  }
  .chip {
    display: inline-flex; align-items: center; gap: 8px;
    min-height: 32px; padding: 6px 10px;
    border: none; background: transparent;
    color: var(--muted); font: inherit; font-size: 13px; line-height: 1.2;
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 180ms ease, color 180ms ease;
  }
  .chip:hover { color: var(--fg); background: var(--bg-sunken); }
  .chip[aria-pressed="true"] { color: var(--fg); background: var(--bg-sunken); }
  .chip:focus-visible { outline: 2px solid var(--fg); outline-offset: 1px; }
  .chip-text {
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    max-width: 280px;
  }
  .chip-sep {
    color: var(--border-strong);
    padding: 0 4px;
    user-select: none;
    font-size: 13px;
  }
  .chip-thumb {
    width: 22px; height: 22px; border-radius: 4px; object-fit: cover;
    display: block;
  }

  /* ─── Sheets: slide-down animation, generous padding ──────────── */
  .meta-sheet {
    padding: 16px 20px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    animation: sheet-in 200ms ease-out;
  }
  @keyframes sheet-in {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .sheet-row {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    margin: 0;
  }
  .sheet-row + .sheet-row { margin-top: 12px; }
  .sheet-label {
    font-size: 13px; color: var(--muted);
    min-width: 88px;
  }
  .sheet-row input[type="text"],
  .sheet-row input[type="date"] {
    flex: 1; min-width: 200px; max-width: 480px;
    height: 40px; padding: 8px 12px;
    font: inherit; font-size: 15px;
    border: 1px solid var(--border); border-radius: 8px;
    background: var(--bg-elev);
    color: var(--fg);
    transition: border-color 180ms ease, box-shadow 180ms ease;
  }
  .sheet-row input[type="text"]:focus,
  .sheet-row input[type="date"]:focus {
    outline: none;
    border-color: var(--fg);
    box-shadow: 0 0 0 3px rgba(9, 9, 11, 0.08);
  }
  .sheet-row-cover { gap: 16px; align-items: flex-start; }
  .upload-status { font-size: 13px; color: var(--muted); align-self: center; }

  /* Cover sheet: bigger, friendlier thumbnail */
  #cover-thumb-wrap {
    position: relative; width: 88px; height: 88px;
    border: 1px solid var(--border); border-radius: 10px; overflow: hidden;
    background: var(--bg-sunken);
    flex: 0 0 auto;
  }
  #cover-thumb { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cover-remove-btn {
    position: absolute; top: 6px; right: 6px;
    width: 22px; height: 22px; min-height: 0; padding: 0;
    border-radius: 50%; line-height: 1;
    background: rgba(0,0,0,0.7); color: #fff; border: none;
    font-size: 14px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background-color 180ms ease;
  }
  .cover-remove-btn:hover { background: rgba(0,0,0,0.85); }
  .cover-upload-btn {
    display: inline-flex; align-items: center; justify-content: center;
    height: 40px; padding: 8px 18px;
    border: 1px solid var(--border-strong); border-radius: 8px;
    background: var(--bg-elev); cursor: pointer;
    font: inherit; font-size: 14px; font-weight: 500;
    color: var(--fg);
    transition: background-color 180ms ease, border-color 180ms ease;
  }
  .cover-upload-btn:hover { background: var(--bg-sunken); }

  /* More sheet: delete as a text-link, not a heavy pill */
  #sheet-more .danger {
    display: inline-flex; align-items: center;
    min-height: 36px; padding: 8px 0;
    border: none; background: transparent;
    color: var(--danger);
    font: inherit; font-size: 14px; font-weight: 500;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    border-radius: 4px;
  }
  #sheet-more .danger:hover { color: #b91c1c; }
  #sheet-more .danger:focus-visible { outline: 2px solid var(--danger); outline-offset: 4px; }

  /* ─── editor surface ─────────────────────────────────────────────── */
  /* Every selector that targets Crepe-managed DOM has to use :global()
     because the .ProseMirror div / .milkdown-image-block etc are
     created at runtime by Crepe -- they don't carry Astro's
     data-astro-cid-* scoping attribute, so unscoped rules silently
     don't match. */
  .milkdown-host {
    flex: 1;
    background: var(--bg-elev);
    overflow-y: auto;
  }
  .milkdown-host :global(.ProseMirror) {
    max-width: 720px; margin: 0 auto;
    padding: 32px 20px 96px;
    min-height: 100%;
    outline: none;
    color: var(--fg);
    box-sizing: border-box;
    // Pass $astro: true so the mixin emits :global(p), :global(h1), etc.
    // instead of & p, & h1. Astro's scoped-CSS pipeline appends
    // [data-astro-cid-*] to every element-name token NOT already inside a
    // :global() wrapper; Crepe-injected DOM has no scope attribute, so the
    // unguarded descendant rules silently fail at runtime. See the mixin
    // partial for the full explanation.
    @include post-typography($astro: true);
  }
  .milkdown-host :global(.ProseMirror a) {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  /* Make every image-block render full-width with its image centered.
     Crepe's defaults give the wrapper `width: fit-content; margin: 0
     auto`, which only centers when the block-level parent has a known
     width -- combined with `min-height: 100px; object-fit: cover` the
     smaller images get cropped + offset. Force a clean centered block:
     image at intrinsic ratio, no min-height, no crop. */
  .milkdown-host :global(.milkdown-image-block) {
    display: block;
    width: 100%;
    margin: 16px 0;
  }
  .milkdown-host :global(.milkdown-image-block .image-wrapper) {
    margin: 0 auto !important;
    max-width: 100%;
  }
  .milkdown-host :global(.milkdown-image-block .image-wrapper img) {
    max-width: 100%;
    height: auto;
    min-height: 0 !important;
    object-fit: contain !important;
    display: block;
  }

  /* Crepe ships several pieces of inline chrome (a drag handle on hover,
     a tooltip toolbar on text selection). The redesign hides them all:
     the bottom toolbar owns formatting, the slash menu stays for power
     users. These selectors target Crepe's own classnames -- if a future
     version renames them, the chrome resurfaces visually but functionally
     nothing breaks. */
  .milkdown-host :global(milkdown-block-handle),
  .milkdown-host :global(.milkdown-block-handle),
  .milkdown-host :global(milkdown-toolbar),
  .milkdown-host :global(.milkdown-toolbar),
  .milkdown-host :global(milkdown-tooltip),
  .milkdown-host :global(.milkdown-tooltip),
  .milkdown-host :global(.crepe-toolbar) {
    display: none !important;
  }

  /* ─── preview area ────────────────────────────────────────────────── */
  .preview-area {
    flex: 1;
    padding: 32px 20px 96px;
    max-width: 720px; margin: 0 auto; width: 100%;
    color: var(--fg);
    overflow-y: auto;
    // $astro: true — see .ProseMirror block above and the mixin partial.
    @include post-typography($astro: true);

    // The preview surface renders the same HTML pipeline as the
    // published post, including `marked.parse` -> sanitize. The
    // mixin's `& img`/`& picture` rule covers margins + max-width;
    // border-radius is a preview-only affordance (no equivalent on
    // published, which doesn't round images) and stays here.
    :global(picture),
    :global(img) {
      border-radius: 4px;
    }
  }
  .preview-placeholder { color: var(--muted-2); font-size: 14px; }

  /* ─── sticky bottom toolbar ──────────────────────────────────────── */
  .bottom-toolbar {
    position: sticky; bottom: 0;
    display: flex; align-items: center; gap: 2px;
    padding: 8px 12px calc(8px + var(--safe-bottom));
    background: var(--bg-elev);
    border-top: 1px solid var(--border);
    z-index: 6;
  }
  .tb {
    width: 40px; height: 40px; min-height: 0; padding: 0;
    border: none; background: transparent;
    border-radius: 8px;
    font: inherit; font-size: 16px; line-height: 1;
    color: var(--fg);
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background-color 180ms ease, color 180ms ease;
  }
  .tb:hover { background: var(--bg-sunken); }
  .tb[aria-pressed="true"] { background: var(--border); }
  .tb:focus-visible { outline: 2px solid var(--fg); outline-offset: 2px; }
  .tb strong { font-weight: 700; }
  .tb em { font-style: italic; }
  .tb-spacer { flex: 1; }
  .upload-progress {
    flex: 1; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden;
    margin: 0 4px;
  }
  .upload-progress-bar {
    height: 100%; width: 0%; background: var(--fg); border-radius: 2px;
    transition: width 80ms linear;
  }
  .tb-image { display: inline-flex; align-items: center; justify-content: center; cursor: pointer; }
  .tb-preview { width: auto; padding: 0 10px; gap: 4px; }
  .tb-label { font-size: 11px; font-weight: 500; }

  /* Respect users who'd rather not see motion. */
  @media (prefers-reduced-motion: reduce) {
    .meta-sheet { animation: none; }
    .icon-btn, .publish-btn, .chip, .tb,
    .sheet-row input[type="text"], .sheet-row input[type="date"],
    .cover-upload-btn, .cover-remove-btn {
      transition: none;
    }
  }
</style>

<script>
  import type { BodyEditor } from '../scripts/body-editor';
  import {
    buildImageMapping,
    expandImageTokens,
    collapseImageTokens,
    rememberImage,
  } from '../scripts/image-tokens';
  import { formatDateChip, formatTagsChip } from '../scripts/post-meta-chips';
  import { compressAndUpload } from '../scripts/image-compress-upload';

  const form = document.getElementById('post-form') as HTMLFormElement;
  const body = document.getElementById('body-area') as HTMLTextAreaElement;
  const editorMount = document.getElementById('milkdown-editor') as HTMLElement;
  const previewArea = document.getElementById('preview-area') as HTMLElement;
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
  const deleteBtn = document.getElementById('delete-btn') as HTMLButtonElement | null;

  // Chips + their hidden form inputs.
  const chipDate = document.getElementById('chip-date') as HTMLButtonElement;
  const chipTags = document.getElementById('chip-tags') as HTMLButtonElement;
  const chipCover = document.getElementById('chip-cover') as HTMLButtonElement;
  const chipCoverText = document.getElementById('chip-cover-text') as HTMLElement;
  const dateInput = document.getElementById('date-input') as HTMLInputElement;
  const tagsInput = document.getElementById('tags-input') as HTMLInputElement;
  const slugInput = document.getElementById('slug-input') as HTMLInputElement;
  const coverIdInput = document.getElementById('cover-image-id') as HTMLInputElement;

  // Sheet editors -- one per chip.
  const datePicker = document.getElementById('date-picker') as HTMLInputElement;
  const tagsEditor = document.getElementById('tags-editor') as HTMLInputElement;
  const slugEditor = document.getElementById('slug-editor') as HTMLInputElement;

  // Cover sheet pieces.
  const coverPicker = document.getElementById('cover-picker') as HTMLInputElement;
  const coverThumbWrap = document.getElementById('cover-thumb-wrap') as HTMLElement;
  const coverThumb = document.getElementById('cover-thumb') as HTMLImageElement;
  const coverRemove = document.getElementById('cover-remove') as HTMLButtonElement;
  const coverStatus = document.getElementById('cover-status') as HTMLElement;
  const coverUploadText = document.getElementById('cover-upload-text') as HTMLElement;

  // Bottom toolbar.
  const bottomToolbar = document.getElementById('bottom-toolbar') as HTMLElement;
  const imagePicker = document.getElementById('image-picker') as HTMLInputElement;
  const previewToggle = document.getElementById('preview-toggle') as HTMLButtonElement;

  const today = form.dataset.today!;

  // ─── editor: Milkdown WYSIWYG-markdown, falls back to textarea ──────────
  let editor: BodyEditor | null = null;
  const initialBodyRaw = body.value;
  const bodyImagesRaw = JSON.parse(form.dataset.bodyImages || '[]') as Array<{ id: string; url: string }>;
  const imageMap = buildImageMapping(bodyImagesRaw);
  const initialBodyExpanded = expandImageTokens(initialBodyRaw, imageMap);
  (async () => {
    try {
      const { mountMilkdownEditor } = await import('../scripts/body-editor-milkdown');
      editor = await mountMilkdownEditor(
        editorMount,
        initialBodyExpanded,
        (md) => { body.value = collapseImageTokens(md, imageMap); },
        {
          uploadImage: (f) => uploadFile(f),
          onImageUploaded: (entry) => {
            rememberImage(imageMap, { id: entry.id, url: entry.url });
            if (entry.editorUrl && entry.editorUrl !== entry.url) {
              rememberImage(imageMap, { id: entry.id, url: entry.editorUrl });
            }
          },
        },
      );
    } catch (err) {
      console.error('Editor failed to load, falling back to textarea:', err);
      body.hidden = false;
      editorMount.style.display = 'none';
      const { mountTextareaEditor } = await import('../scripts/body-editor');
      editor = mountTextareaEditor(body, initialBodyRaw);
    }
  })();

  const currentBody = () => {
    if (editor) return collapseImageTokens(editor.getMarkdown(), imageMap);
    return body.value;
  };

  const siteId = form.dataset.siteId!;
  const postId = form.dataset.postId || null;
  const mode = form.dataset.mode!;

  // ─── meta sheets: only one open at a time ───────────────────────────
  const sheets = new Map<string, HTMLElement>([
    ['date', document.getElementById('sheet-date') as HTMLElement],
    ['tags', document.getElementById('sheet-tags') as HTMLElement],
    ['cover', document.getElementById('sheet-cover') as HTMLElement],
    ['more', document.getElementById('sheet-more') as HTMLElement],
  ]);
  const chipMore = document.getElementById('chip-more') as HTMLButtonElement;
  const chipBySheet = new Map<string, HTMLButtonElement | null>([
    ['date', chipDate],
    ['tags', chipTags],
    ['cover', chipCover],
    ['more', chipMore],
  ]);

  function openSheet(name: string) {
    for (const [n, el] of sheets) {
      const open = n === name;
      el.hidden = !open;
      const chip = chipBySheet.get(n);
      if (chip) chip.setAttribute('aria-pressed', open ? 'true' : 'false');
    }
  }
  function closeSheets() {
    for (const [, el] of sheets) el.hidden = true;
    for (const [, chip] of chipBySheet) if (chip) chip.setAttribute('aria-pressed', 'false');
  }

  document.querySelectorAll<HTMLButtonElement>('[data-sheet]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const name = btn.dataset.sheet!;
      const sheet = sheets.get(name);
      if (!sheet) return;
      if (sheet.hidden) openSheet(name);
      else closeSheets();
    });
  });

  // ─── chip ⇄ hidden input wiring ─────────────────────────────────────
  // Mobile date pickers (especially iOS) sometimes fire `input` instead
  // of `change`, and vice versa on desktop. Listen to both so the chip
  // text and the hidden form input stay in sync no matter how the user
  // picks the date.
  const updateDateChip = () => {
    const v = datePicker.value;
    dateInput.value = v;
    chipDate.querySelector('.chip-text')!.textContent = formatDateChip(v || null, today);
  };
  datePicker.addEventListener('change', updateDateChip);
  datePicker.addEventListener('input', updateDateChip);

  const updateTagsChip = () => {
    tagsInput.value = tagsEditor.value;
    chipTags.querySelector('.chip-text')!.textContent = formatTagsChip(tagsEditor.value);
  };
  tagsEditor.addEventListener('input', updateTagsChip);
  tagsEditor.addEventListener('change', updateTagsChip);

  slugEditor.addEventListener('input', () => { slugInput.value = slugEditor.value; });
  slugEditor.addEventListener('change', () => { slugInput.value = slugEditor.value; });

  // ─── upload progress bar ────────────────────────────────────────────
  const uploadProgress = document.getElementById('upload-progress') as HTMLElement;
  const uploadProgressBar = document.getElementById('upload-progress-bar') as HTMLElement;

  function showProgress(pct: number) {
    uploadProgress.hidden = false;
    uploadProgressBar.style.width = `${pct}%`;
    if (pct >= 100) setTimeout(() => { uploadProgress.hidden = true; uploadProgressBar.style.width = '0%'; }, 400);
  }

  function uploadFile(file: File) {
    return compressAndUpload(file, siteId, () => {}, showProgress);
  }

  // ─── cover image ────────────────────────────────────────────────────
  function setCover(id: string, url: string) {
    coverIdInput.value = id;
    coverThumb.src = url;
    coverThumbWrap.style.display = '';
    coverUploadText.textContent = 'replace';
    // Refresh the chip: thumbnail + "cover" label.
    chipCover.dataset.hasCover = 'true';
    chipCoverText.textContent = 'cover';
    const existingThumb = document.getElementById('chip-cover-thumb');
    if (existingThumb) {
      (existingThumb as HTMLImageElement).src = url;
    } else {
      const img = document.createElement('img');
      img.id = 'chip-cover-thumb';
      img.className = 'chip-thumb';
      img.src = url; img.alt = '';
      chipCover.insertBefore(img, chipCoverText);
    }
  }
  function clearCover() {
    coverIdInput.value = '';
    coverThumb.src = '';
    coverThumbWrap.style.display = 'none';
    coverUploadText.textContent = '+ choose cover';
    chipCover.dataset.hasCover = 'false';
    chipCoverText.textContent = '+ cover';
    const existingThumb = document.getElementById('chip-cover-thumb');
    if (existingThumb) existingThumb.remove();
  }
  coverPicker.addEventListener('change', async () => {
    const f = coverPicker.files?.[0];
    coverPicker.value = '';
    if (!f) return;
    coverStatus.textContent = `uploading cover…`;
    const r = await uploadFile(f);
    if (!r) { coverStatus.textContent = 'cover upload failed'; return; }
    setCover(r.id, r.url);
    coverStatus.textContent = '';
  });
  coverRemove.addEventListener('click', () => clearCover());

  // ─── bottom toolbar bindings ────────────────────────────────────────
  bottomToolbar.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-cmd]');
    if (!btn || !editor) return;
    const cmd = btn.dataset.cmd!;
    switch (cmd) {
      case 'bold': editor.toggleBold(); break;
      case 'italic': editor.toggleItalic(); break;
      case 'blockquote': editor.toggleBlockquote(); break;
      case 'list': editor.toggleBulletList(); break;
      case 'link': {
        const url = prompt('Link URL');
        if (url) editor.insertLink(url);
        break;
      }
      case 'preview': togglePreview(); break;
    }
  });

  imagePicker.addEventListener('change', async () => {
    const files = Array.from(imagePicker.files ?? []);
    imagePicker.value = '';
    for (const file of files) {
      let blobUrl: string | null = null;
      const r = await compressAndUpload(
        file,
        siteId,
        (preview) => {
          blobUrl = preview;
          if (editor) editor.insertImageBlock(preview);
        },
        showProgress,
      );
      if (!r) continue;
      const renderUrl = r.editorUrl ?? r.url;
      if (blobUrl) rememberImage(imageMap, { id: r.id, url: blobUrl });
      if (renderUrl !== r.url) rememberImage(imageMap, { id: r.id, url: r.url });
      rememberImage(imageMap, { id: r.id, url: renderUrl });
      if (editor) {
        if (!blobUrl) editor.insertImageBlock(renderUrl);
        body.value = collapseImageTokens(editor.getMarkdown(), imageMap);
      } else {
        body.value += `\n![](image:${r.id})\n`;
      }
    }
  });

  // ─── preview toggle (replaces the write/preview tabs) ───────────────
  async function togglePreview() {
    const showingPreview = !previewArea.hidden;
    if (showingPreview) {
      previewArea.hidden = true;
      editorMount.style.display = '';
      previewToggle.setAttribute('aria-pressed', 'false');
      return;
    }
    previewArea.hidden = false;
    editorMount.style.display = 'none';
    previewToggle.setAttribute('aria-pressed', 'true');
    previewArea.innerHTML = '<div class="preview-placeholder">rendering…</div>';
    const r = await fetch('/admin/api/preview', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ siteId, body: currentBody() }),
    });
    if (!r.ok) {
      previewArea.innerHTML = `<div class="preview-placeholder">preview failed</div>`;
      return;
    }
    const html = await r.text();
    previewArea.innerHTML = html || '<div class="preview-placeholder">nothing to preview yet…</div>';
  }

  // ─── save / delete ──────────────────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    const originalLabel = saveBtn.textContent;
    saveBtn.textContent = 'saving…';
    const fd = new FormData(form);
    const payload = {
      mode, postId, siteId,
      title: fd.get('title'),
      slug: fd.get('slug') || undefined,
      date: fd.get('date'),
      body: currentBody(),
      tagNames: String(fd.get('tags') ?? '').split(',').map((s) => s.trim()).filter(Boolean),
      coverImageId: coverIdInput.value || null,
    };
    const r = await fetch('/admin/api/save', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!r.ok) {
      saveBtn.disabled = false;
      saveBtn.textContent = originalLabel;
      alert('save failed: ' + await r.text());
      return;
    }
    const { id } = await r.json() as { id: string };
    location.href = `/admin/edit/${id}`;
  });

  deleteBtn?.addEventListener('click', async () => {
    if (!postId) return;
    if (!confirm('delete this post?')) return;
    const r = await fetch('/admin/api/delete', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ postId, siteId }),
    });
    if (!r.ok) { alert('delete failed: ' + await r.text()); return; }
    location.href = '/admin';
  });
</script>
