---
import AdminLayout from '~/layouts/AdminLayout.astro';
import type { Album } from '~/lib/db/albums';

interface InitialImage {
  imageId: string;
  r2Key: string;
  width: number;
  height: number;
  variantWidths: number[] | null;
  caption: string | null;
}

interface Props {
  mode: 'new' | 'edit';
  siteId: string;
  album?: Album;
  initialImages?: InitialImage[];
}

const { mode, siteId, album, initialImages = [] } = Astro.props;
const photoCount = initialImages.length;
---
<AdminLayout bare>
  <div class="ae">
    <!-- Sticky header -->
    <div class="ae-header">
      <a href="/admin/gallery" class="ae-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        <span>Albums</span>
      </a>
      <span class="ae-title">{mode === 'new' ? 'New album' : 'Edit album'}</span>
      <div class="ae-actions">
        {mode === 'edit' && (
          <button type="button" id="btn-delete" class="ae-btn ae-btn--danger" aria-label="Delete album">Delete</button>
        )}
        <button type="button" id="btn-save" class="ae-btn ae-btn--primary" aria-label="Save album">Save</button>
      </div>
    </div>

    <!-- Body -->
    <div class="ae-body">
      <div class="ae-field">
        <label for="f-title" class="ae-label">Title</label>
        <input id="f-title" class="ae-input" type="text" placeholder="Album title" value={album?.title ?? ''} autocomplete="off" />
      </div>

      <div class="ae-field">
        <label for="f-slug" class="ae-label">Slug</label>
        <input id="f-slug" class="ae-input" type="text" placeholder="album-slug" value={album?.slug ?? ''} autocomplete="off" />
      </div>

      <div class="ae-field">
        <label for="f-desc" class="ae-label">Description</label>
        <textarea id="f-desc" class="ae-input ae-textarea" rows="3" placeholder="Optional description">{album?.description ?? ''}</textarea>
      </div>

      <div class="ae-field-check">
        <input id="f-published" type="checkbox" checked={album?.published ?? true} />
        <label for="f-published">Published</label>
      </div>

      <!-- Photos section -->
      <div class="ae-photos-header">
        <span class="ae-label" id="photos-count-label">Photos{photoCount > 0 ? ` · ${photoCount}` : ''}</span>
        <button type="button" id="btn-add-images" class="ae-btn ae-btn--add" aria-label="Add photos">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
          Add photos
        </button>
      </div>
      <input id="f-images" type="file" accept="image/*" multiple style="display:none" />
      <span id="upload-status" class="ae-upload-status" aria-live="polite"></span>

      <div id="image-grid" class="ae-grid">
        <!-- thumbnails injected by JS -->
      </div>
    </div>
  </div>

  <script
    id="album-data"
    type="application/json"
    set:html={JSON.stringify({
      mode,
      siteId,
      albumId: album?.id ?? null,
      initialImages,
    })}
  />
</AdminLayout>

<script>
import { slugify } from '~/lib/slug';

const dataEl = document.getElementById('album-data') as HTMLScriptElement;
const { mode, siteId, albumId, initialImages } = JSON.parse(dataEl.textContent!);

type UploadedImage = {
  imageId: string;
  previewUrl: string;
  width: number;
  height: number;
};

const images: UploadedImage[] = initialImages.map((img: any) => {
  const w = (img.variantWidths ?? []).includes(400) ? 400 : (img.variantWidths?.[0] ?? null);
  const previewUrl = w
    ? `/img/${img.r2Key.replace(/\.(jpe?g|png|webp|gif)$/i, '')}.${w}w.jpg`
    : `/img/${img.r2Key}`;
  return { imageId: img.imageId, previewUrl, width: img.width, height: img.height };
});

const titleInput = document.getElementById('f-title') as HTMLInputElement;
const slugInput = document.getElementById('f-slug') as HTMLInputElement;
const descInput = document.getElementById('f-desc') as HTMLTextAreaElement;
const publishedInput = document.getElementById('f-published') as HTMLInputElement;
const fileInput = document.getElementById('f-images') as HTMLInputElement;
const btnAddImages = document.getElementById('btn-add-images') as HTMLButtonElement;
const uploadStatus = document.getElementById('upload-status') as HTMLSpanElement;
const imageGrid = document.getElementById('image-grid') as HTMLDivElement;
const photosLabel = document.getElementById('photos-count-label') as HTMLSpanElement;
const btnSave = document.getElementById('btn-save') as HTMLButtonElement;
const btnDelete = document.getElementById('btn-delete') as HTMLButtonElement | null;

let lastAutoSlug = slugify(titleInput.value);
titleInput.addEventListener('input', () => {
  const auto = slugify(titleInput.value);
  if (slugInput.value === '' || slugInput.value === lastAutoSlug) {
    slugInput.value = auto;
    lastAutoSlug = auto;
  }
});

function updatePhotosLabel() {
  photosLabel.textContent = images.length > 0 ? `Photos · ${images.length}` : 'Photos';
}

function renderGrid() {
  imageGrid.innerHTML = '';
  images.forEach((img, i) => {
    const cell = document.createElement('div');
    cell.className = 'ae-thumb';
    cell.innerHTML = `
      <img src="${img.previewUrl}" alt="" loading="lazy" />
      <button class="ae-thumb-remove" data-index="${i}" type="button" aria-label="Remove photo">×</button>
    `;
    cell.querySelector<HTMLButtonElement>('.ae-thumb-remove')!.addEventListener('click', () => {
      images.splice(i, 1);
      renderGrid();
      updatePhotosLabel();
    });
    imageGrid.appendChild(cell);
  });
  updatePhotosLabel();
}
renderGrid();

btnAddImages.addEventListener('click', () => fileInput.click());

const VARIANT_TARGETS = [400, 800, 1200, 1600, 2400];

async function resizeAt(
  bitmap: ImageBitmap,
  targetWidth: number,
  type: string,
  quality = 0.80,
): Promise<{ blob: Blob; width: number; height: number } | null> {
  const ratio = Math.min(1, targetWidth / bitmap.width);
  const w = Math.round(bitmap.width * ratio);
  const h = Math.round(bitmap.height * ratio);
  const canvas = document.createElement('canvas');
  canvas.width = w; canvas.height = h;
  canvas.getContext('2d')!.drawImage(bitmap, 0, 0, w, h);
  const blob = await new Promise<Blob | null>((res) => canvas.toBlob(res, type, quality));
  return blob ? { blob, width: w, height: h } : null;
}

async function compressAndUpload(file: File): Promise<{ id: string; url: string; editorUrl: string; variantWidths: number[] } | null> {
  const bitmap = await createImageBitmap(file, { imageOrientation: 'from-image' });
  const wantWidths = VARIANT_TARGETS.filter((w) => w <= bitmap.width);
  if (wantWidths.length === 0) wantWidths.push(bitmap.width);
  const [jpegResults, webpResults] = await Promise.all([
    Promise.all(wantWidths.map((w) => resizeAt(bitmap, w, 'image/jpeg', 0.80))),
    Promise.all(wantWidths.map((w) => resizeAt(bitmap, w, 'image/webp', 0.80))),
  ]);
  const jpegs = jpegResults.filter((r): r is NonNullable<typeof r> => r !== null);
  if (jpegs.length === 0) return null;
  const webps = webpResults.filter((r): r is NonNullable<typeof r> => r !== null);
  jpegs.sort((a, b) => b.width - a.width);
  webps.sort((a, b) => b.width - a.width);
  const stem = file.name.replace(/\.[^.]+$/, '');
  const fd = new FormData();
  fd.append('siteId', siteId);
  for (const v of jpegs) fd.append(`file_${v.width}`, v.blob, `${stem}.${v.width}w.jpg`);
  for (const v of webps) fd.append(`file_${v.width}_webp`, v.blob, `${stem}.${v.width}w.webp`);
  const resp = await fetch('/admin/api/upload', { method: 'POST', body: fd });
  if (!resp.ok) return null;
  return resp.json();
}

fileInput.addEventListener('change', async () => {
  const files = Array.from(fileInput.files ?? []);
  if (!files.length) return;
  fileInput.value = '';

  for (const file of files) {
    uploadStatus.textContent = `Uploading ${file.name}…`;
    btnSave.disabled = true;
    try {
      const data = await compressAndUpload(file);
      if (!data) throw new Error('compression or upload failed');
      images.push({ imageId: data.id, previewUrl: data.editorUrl, width: 0, height: 0 });
      renderGrid();
    } catch (e) {
      uploadStatus.textContent = `Upload failed: ${(e as Error).message}`;
    } finally {
      btnSave.disabled = false;
    }
  }
  uploadStatus.textContent = '';
});

btnSave.addEventListener('click', async () => {
  const title = titleInput.value.trim();
  if (!title) { alert('Title is required'); return; }
  const slug = slugInput.value.trim() || slugify(title);
  if (!slug) { alert('Could not derive slug'); return; }

  btnSave.disabled = true;
  btnSave.textContent = 'Saving…';
  try {
    const body = {
      mode,
      albumId,
      siteId,
      title,
      slug,
      description: descInput.value.trim() || null,
      published: publishedInput.checked,
      imageIds: images.map(img => img.imageId),
    };
    const resp = await fetch('/admin/api/gallery-save', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (!resp.ok) throw new Error(await resp.text());
    const data = await resp.json() as { id: string; slug: string };
    window.location.href = `/admin/gallery/edit/${data.id}`;
  } catch (e) {
    alert(`Save failed: ${(e as Error).message}`);
    btnSave.disabled = false;
    btnSave.textContent = 'Save';
  }
});

btnDelete?.addEventListener('click', async () => {
  if (!confirm('Delete this album? This cannot be undone.')) return;
  btnDelete.disabled = true;
  try {
    const resp = await fetch('/admin/api/gallery-delete', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ albumId, siteId }),
    });
    if (!resp.ok) throw new Error(await resp.text());
    window.location.href = '/admin/gallery';
  } catch (e) {
    alert(`Delete failed: ${(e as Error).message}`);
    btnDelete.disabled = false;
  }
});
</script>

<style>
/* ── Layout shell ────────────────────────────────────────────────────────── */
.ae {
  display: flex;
  flex-direction: column;
  min-height: 100dvh;
}

/* ── Sticky header ────────────────────────────────────────────────────────── */
.ae-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: calc(var(--safe-top, 0px) + 14px) 20px 14px;
  border-bottom: 1px solid var(--border);
  background: var(--bg-elev);
  position: sticky;
  top: 0;
  z-index: 10;
}

.ae-back {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 13px;
  color: var(--muted);
  white-space: nowrap;
  text-decoration: none;
  cursor: pointer;
  transition: color 150ms ease;

  &:hover { color: var(--text); }

  svg { flex-shrink: 0; }
}

.ae-title {
  font-size: 14px;
  font-weight: 600;
  flex: 1;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ae-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

/* ── Buttons ─────────────────────────────────────────────────────────────── */
.ae-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  height: 34px;
  padding: 0 14px;
  border-radius: 7px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  border: 1.5px solid transparent;
  transition: opacity 150ms ease, background 150ms ease;

  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
}

.ae-btn--primary {
  background: var(--text, #0f0f0f);
  color: var(--bg, #fff);
  border-color: var(--text, #0f0f0f);

  &:hover:not(:disabled) { opacity: 0.8; }
}

.ae-btn--danger {
  background: transparent;
  color: #d94f4f;
  border-color: #d94f4f;

  &:hover:not(:disabled) { background: #fdf0f0; }
}

.ae-btn--add {
  background: transparent;
  color: var(--text);
  border-color: var(--border);
  height: 30px;
  padding: 0 10px;
  font-size: 12px;

  &:hover:not(:disabled) { background: var(--bg-sunken); }
}

/* ── Body ────────────────────────────────────────────────────────────────── */
.ae-body {
  padding: 24px 20px 60px;
  max-width: 680px;
  margin: 0 auto;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* ── Labels ──────────────────────────────────────────────────────────────── */
.ae-label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 6px;
}

/* ── Fields ──────────────────────────────────────────────────────────────── */
.ae-field {
  display: flex;
  flex-direction: column;
}

.ae-input {
  width: 100%;
  padding: 10px 13px;
  border: 1.5px solid var(--border);
  border-radius: 7px;
  background: var(--bg);
  color: var(--text);
  font-size: 14px;
  font-family: inherit;
  line-height: 1.5;
  transition: border-color 150ms ease;
  box-sizing: border-box;

  &:focus {
    outline: none;
    border-color: var(--text);
  }

  &::placeholder { color: var(--muted); opacity: 0.6; }
}

.ae-textarea {
  resize: vertical;
  min-height: 80px;
}

.ae-field-check {
  display: flex;
  align-items: center;
  gap: 8px;

  input[type="checkbox"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
  }

  label {
    font-size: 14px;
    cursor: pointer;
    user-select: none;
  }
}

/* ── Photos section ──────────────────────────────────────────────────────── */
.ae-photos-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;

  .ae-label { margin-bottom: 0; }
}

.ae-upload-status {
  font-size: 12px;
  color: var(--muted);
  min-height: 1em;
}

/* ── Photo grid ──────────────────────────────────────────────────────────── */
.ae-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

/* :global because thumbnails are injected dynamically by JS and won't carry
   Astro's scoped CSS data attribute. */
:global(.ae-thumb) {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 6px;
  background: var(--bg-sunken);
}

:global(.ae-thumb img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

:global(.ae-thumb-remove) {
  position: absolute;
  top: 5px;
  right: 5px;
  width: 24px;
  height: 24px;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 15px;
  line-height: 1;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 150ms ease;
}

:global(.ae-thumb-remove:hover) {
  background: rgba(0, 0, 0, 0.85);
}

/* ── Mobile ──────────────────────────────────────────────────────────────── */
@media (max-width: 480px) {
  .ae-header {
    padding: calc(var(--safe-top, 0px) + 12px) 14px 12px;
    gap: 8px;
  }

  .ae-back span { display: none; }

  .ae-body {
    padding: 18px 14px 60px;
    gap: 16px;
  }

  .ae-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }
}
</style>
