---
import AdminLayout from '~/layouts/AdminLayout.astro';
import type { Album } from '~/lib/db/albums';

interface InitialImage {
  imageId: string;
  r2Key: string;
  width: number;
  height: number;
  variantWidths: number[] | null;
  caption: string | null;
}

interface Props {
  mode: 'new' | 'edit';
  siteId: string;
  album?: Album;
  initialImages?: InitialImage[];
}

const { mode, siteId, album, initialImages = [] } = Astro.props;
const photoCount = initialImages.length;
---
<AdminLayout bare>
  <div class="ae">
    <!-- Sticky header -->
    <div class="ae-header">
      <a href="/admin/gallery" class="ae-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        <span>Albums</span>
      </a>
      <span class="ae-title">{mode === 'new' ? 'New album' : 'Edit album'}</span>
      <div class="ae-actions">
        {mode === 'edit' && (
          <button type="button" id="btn-delete" class="ae-btn ae-btn--danger" aria-label="Delete album">Delete</button>
        )}
        <button type="button" id="btn-save" class="ae-btn ae-btn--primary" aria-label="Save album">Save</button>
      </div>
    </div>

    <!-- Body -->
    <div class="ae-body">
      <div class="ae-field">
        <label for="f-title" class="ae-label">Title</label>
        <input id="f-title" class="ae-input" type="text" placeholder="Album title" value={album?.title ?? ''} autocomplete="off" />
      </div>

      <div class="ae-field">
        <label for="f-slug" class="ae-label">Slug</label>
        <input id="f-slug" class="ae-input" type="text" placeholder="album-slug" value={album?.slug ?? ''} autocomplete="off" />
      </div>

      <div class="ae-field">
        <label for="f-desc" class="ae-label">Description</label>
        <textarea id="f-desc" class="ae-input ae-textarea" rows="3" placeholder="Optional description">{album?.description ?? ''}</textarea>
      </div>

      <div class="ae-field-check">
        <input id="f-published" type="checkbox" checked={album?.published ?? true} />
        <label for="f-published">Published</label>
      </div>

      <!-- Photos section -->
      <div class="ae-photos-header">
        <span class="ae-label" id="photos-count-label">Photos{photoCount > 0 ? ` · ${photoCount}` : ''}</span>
        <button type="button" id="btn-add-images" class="ae-btn ae-btn--add" aria-label="Add photos">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
          Add photos
        </button>
      </div>
      <input id="f-images" type="file" accept="image/*" multiple style="display:none" />

      <div id="image-grid" class="ae-grid">
        <!-- thumbnails injected by JS -->
      </div>
    </div>
  </div>

  <script
    id="album-data"
    type="application/json"
    set:html={JSON.stringify({
      mode,
      siteId,
      albumId: album?.id ?? null,
      initialImages,
    })}
  />
</AdminLayout>

<script>
import { slugify } from '~/lib/slug';
import { compressAndUpload } from '../scripts/image-compress-upload';

const dataEl = document.getElementById('album-data') as HTMLScriptElement;
const { mode, siteId, albumId, initialImages } = JSON.parse(dataEl.textContent!);

type UploadStatus = 'done' | 'uploading' | 'failed';

type UploadedImage = {
  imageId: string;
  previewUrl: string;
  width: number;
  height: number;
  status: UploadStatus;
  /** 0–100 while uploading. Undefined for 'done' and 'failed'. */
  progress?: number;
  /** Kept on failure so the retry button can re-upload the same File. */
  file?: File;
  /** Last error message, surfaced via title attr on the failed overlay. */
  error?: string;
};

const images: UploadedImage[] = initialImages.map((img: any) => {
  const w = (img.variantWidths ?? []).includes(400) ? 400 : (img.variantWidths?.[0] ?? null);
  const previewUrl = w
    ? `/img/${img.r2Key.replace(/\.(jpe?g|png|webp|gif)$/i, '')}.${w}w.webp`
    : `/img/${img.r2Key}`;
  return {
    imageId: img.imageId, previewUrl,
    width: img.width, height: img.height,
    status: 'done' as const,
  };
});

const titleInput = document.getElementById('f-title') as HTMLInputElement;
const slugInput = document.getElementById('f-slug') as HTMLInputElement;
const descInput = document.getElementById('f-desc') as HTMLTextAreaElement;
const publishedInput = document.getElementById('f-published') as HTMLInputElement;
const fileInput = document.getElementById('f-images') as HTMLInputElement;
const btnAddImages = document.getElementById('btn-add-images') as HTMLButtonElement;
const imageGrid = document.getElementById('image-grid') as HTMLDivElement;
const photosLabel = document.getElementById('photos-count-label') as HTMLSpanElement;
const btnSave = document.getElementById('btn-save') as HTMLButtonElement;
const btnDelete = document.getElementById('btn-delete') as HTMLButtonElement | null;

let lastAutoSlug = slugify(titleInput.value);
titleInput.addEventListener('input', () => {
  const auto = slugify(titleInput.value);
  if (slugInput.value === '' || slugInput.value === lastAutoSlug) {
    slugInput.value = auto;
    lastAutoSlug = auto;
  }
});

function updatePhotosLabel() {
  photosLabel.textContent = images.length > 0 ? `Photos · ${images.length}` : 'Photos';
}

// Per-thumbnail render. Each cell carries an overlay that reflects the
// image's current status — uploading shows a circular progress ring;
// failed shows a retry button; done shows just the remove (×) button.
function renderCell(img: UploadedImage, i: number): HTMLDivElement {
  const cell = document.createElement('div');
  cell.className = 'ae-thumb';
  cell.dataset.status = img.status;
  cell.innerHTML = `
    <img src="${img.previewUrl}" alt="" loading="lazy" />
    <div class="ae-thumb-overlay"></div>
    ${img.status === 'uploading' ? renderProgressRing(img.progress ?? 0) : ''}
    ${img.status === 'failed' ? `
      <button class="ae-thumb-retry" type="button" aria-label="Retry upload" title="${escapeAttr(img.error ?? 'Upload failed')}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12a9 9 0 0 1 15.5-6.4L21 8"/><path d="M21 3v5h-5"/>
          <path d="M21 12a9 9 0 0 1-15.5 6.4L3 16"/><path d="M3 21v-5h5"/>
        </svg>
      </button>` : ''}
    <button class="ae-thumb-remove" type="button" aria-label="Remove photo">×</button>
  `;
  cell.querySelector<HTMLButtonElement>('.ae-thumb-remove')!.addEventListener('click', () => {
    images.splice(i, 1);
    renderGrid();
  });
  const retry = cell.querySelector<HTMLButtonElement>('.ae-thumb-retry');
  if (retry) retry.addEventListener('click', () => { void retryUpload(i); });
  return cell;
}

function renderProgressRing(pct: number): string {
  // SVG circle stroked at stroke-dasharray = circumference. Smaller
  // dashoffset → more arc visible.
  const r = 18;
  const c = 2 * Math.PI * r;
  const dash = c * (1 - pct / 100);
  return `
    <svg class="ae-thumb-progress" width="44" height="44" viewBox="0 0 44 44" aria-hidden="true">
      <circle class="ae-ring-track" cx="22" cy="22" r="${r}" />
      <circle class="ae-ring-bar" cx="22" cy="22" r="${r}"
        stroke-dasharray="${c}" stroke-dashoffset="${dash}"
        transform="rotate(-90 22 22)" />
    </svg>`;
}

function escapeAttr(s: string): string {
  return s.replace(/[&<>"']/g, (c) =>
    ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]!);
}

function renderGrid() {
  imageGrid.innerHTML = '';
  images.forEach((img, i) => imageGrid.appendChild(renderCell(img, i)));
  updatePhotosLabel();
  updateSaveState();
}

// Touch only the cell that changed — full re-render would break the
// progress ring's CSS animation on every frame.
function patchCell(index: number) {
  const cells = imageGrid.children;
  const next = renderCell(images[index], index);
  if (cells[index]) cells[index].replaceWith(next);
  updateSaveState();
}

function updateSaveState() {
  const anyUploading = images.some((img) => img.status === 'uploading');
  btnSave.disabled = anyUploading;
}

renderGrid();

btnAddImages.addEventListener('click', () => fileInput.click());

// ── Parallel uploads with a small concurrency cap ───────────────────────
// Three concurrent uploads is a sweet spot for R2: more than that and
// browser connection limits per host throttle them anyway. Each upload
// owns the index of its image entry; status flips through 'uploading'
// → 'done' (or 'failed'), and patchCell repaints just that thumb.
const MAX_CONCURRENT = 3;
let activeUploads = 0;
const queue: number[] = [];

function pumpQueue() {
  while (activeUploads < MAX_CONCURRENT && queue.length > 0) {
    const idx = queue.shift()!;
    activeUploads++;
    void runUpload(idx).finally(() => { activeUploads--; pumpQueue(); });
  }
}

async function runUpload(index: number) {
  const entry = images[index];
  if (!entry || !entry.file) return;
  entry.status = 'uploading';
  entry.progress = 0;
  entry.error = undefined;
  patchCell(index);
  try {
    const data = await compressAndUpload(
      entry.file,
      siteId,
      (blobUrl) => {
        // The compressed preview is available before the upload
        // finishes — swap the thumb's src so the user sees the
        // already-resized version instead of the raw multi-MB jpeg.
        entry.previewUrl = blobUrl;
        patchCell(index);
      },
      (pct) => {
        const cur = images[index];
        if (!cur || cur.status !== 'uploading') return;
        cur.progress = pct;
        // Lightweight progress update: nudge the ring's dashoffset
        // directly instead of re-rendering the whole cell. Falls back
        // to patchCell if the ring isn't in the DOM yet.
        const ring = imageGrid.children[index]?.querySelector<SVGCircleElement>('.ae-ring-bar');
        if (ring) {
          const r = 18; const c = 2 * Math.PI * r;
          ring.setAttribute('stroke-dashoffset', String(c * (1 - pct / 100)));
        } else {
          patchCell(index);
        }
      },
    );
    if (!data) throw new Error('compression or upload failed');
    entry.imageId = data.id;
    entry.previewUrl = data.editorUrl ?? data.url;
    entry.status = 'done';
    entry.progress = undefined;
    entry.file = undefined;
  } catch (e) {
    entry.status = 'failed';
    entry.progress = undefined;
    entry.error = (e as Error).message;
  } finally {
    patchCell(index);
  }
}

function retryUpload(index: number) {
  const entry = images[index];
  if (!entry || entry.status !== 'failed' || !entry.file) return;
  queue.push(index);
  pumpQueue();
}

fileInput.addEventListener('change', () => {
  const files = Array.from(fileInput.files ?? []);
  if (!files.length) return;
  fileInput.value = '';
  for (const file of files) {
    // Provisional cell: blob URL as placeholder so the user sees
    // something instantly even before compression starts.
    const blobPreview = URL.createObjectURL(file);
    images.push({
      imageId: '',
      previewUrl: blobPreview,
      width: 0, height: 0,
      status: 'uploading',
      progress: 0,
      file,
    });
    renderGrid();
    queue.push(images.length - 1);
  }
  pumpQueue();
});

btnSave.addEventListener('click', async () => {
  const title = titleInput.value.trim();
  if (!title) { alert('Title is required'); return; }
  const slug = slugInput.value.trim() || slugify(title);
  if (!slug) { alert('Could not derive slug'); return; }

  btnSave.disabled = true;
  btnSave.textContent = 'Saving…';
  try {
    const body = {
      mode,
      albumId,
      siteId,
      title,
      slug,
      description: descInput.value.trim() || null,
      published: publishedInput.checked,
      // Only persist successfully uploaded images. The 'uploading'
      // path is guarded by updateSaveState() disabling Save, but
      // 'failed' rows can still be present and must be skipped.
      imageIds: images.filter((img) => img.status === 'done' && img.imageId).map((img) => img.imageId),
    };
    const resp = await fetch('/admin/api/gallery-save', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (!resp.ok) throw new Error(await resp.text());
    const data = await resp.json() as { id: string; slug: string };
    window.location.href = `/admin/gallery/edit/${data.id}`;
  } catch (e) {
    alert(`Save failed: ${(e as Error).message}`);
    btnSave.disabled = false;
    btnSave.textContent = 'Save';
  }
});

btnDelete?.addEventListener('click', async () => {
  if (!confirm('Delete this album? This cannot be undone.')) return;
  btnDelete.disabled = true;
  try {
    const resp = await fetch('/admin/api/gallery-delete', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ albumId, siteId }),
    });
    if (!resp.ok) throw new Error(await resp.text());
    window.location.href = '/admin/gallery';
  } catch (e) {
    alert(`Delete failed: ${(e as Error).message}`);
    btnDelete.disabled = false;
  }
});
</script>

<style>
/* ── Layout shell ────────────────────────────────────────────────────────── */
.ae {
  display: flex;
  flex-direction: column;
  min-height: 100dvh;
}

/* ── Sticky header ────────────────────────────────────────────────────────── */
.ae-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: calc(var(--safe-top, 0px) + 14px) 20px 14px;
  border-bottom: 1px solid var(--border);
  background: var(--bg-elev);
  position: sticky;
  top: 0;
  z-index: 10;
}

.ae-back {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 13px;
  color: var(--muted);
  white-space: nowrap;
  text-decoration: none;
  cursor: pointer;
  transition: color 150ms ease;

  &:hover { color: var(--text); }

  svg { flex-shrink: 0; }
}

.ae-title {
  font-size: 14px;
  font-weight: 600;
  flex: 1;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ae-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

/* ── Buttons ─────────────────────────────────────────────────────────────── */
.ae-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  height: 34px;
  padding: 0 14px;
  border-radius: 7px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  border: 1.5px solid transparent;
  transition: opacity 150ms ease, background 150ms ease;

  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
}

.ae-btn--primary {
  background: var(--text, #0f0f0f);
  color: var(--bg, #fff);
  border-color: var(--text, #0f0f0f);

  &:hover:not(:disabled) { opacity: 0.8; }
}

.ae-btn--danger {
  background: transparent;
  color: #d94f4f;
  border-color: #d94f4f;

  &:hover:not(:disabled) { background: #fdf0f0; }
}

.ae-btn--add {
  background: transparent;
  color: var(--text);
  border-color: var(--border);
  height: 30px;
  padding: 0 10px;
  font-size: 12px;

  &:hover:not(:disabled) { background: var(--bg-sunken); }
}

/* ── Body ────────────────────────────────────────────────────────────────── */
.ae-body {
  padding: 24px 20px 60px;
  max-width: 680px;
  margin: 0 auto;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* ── Labels ──────────────────────────────────────────────────────────────── */
.ae-label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 6px;
}

/* ── Fields ──────────────────────────────────────────────────────────────── */
.ae-field {
  display: flex;
  flex-direction: column;
}

.ae-input {
  width: 100%;
  padding: 10px 13px;
  border: 1.5px solid var(--border);
  border-radius: 7px;
  background: var(--bg);
  color: var(--text);
  font-size: 14px;
  font-family: inherit;
  line-height: 1.5;
  transition: border-color 150ms ease;
  box-sizing: border-box;

  &:focus {
    outline: none;
    border-color: var(--text);
  }

  &::placeholder { color: var(--muted); opacity: 0.6; }
}

.ae-textarea {
  resize: vertical;
  min-height: 80px;
}

.ae-field-check {
  display: flex;
  align-items: center;
  gap: 8px;

  input[type="checkbox"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
  }

  label {
    font-size: 14px;
    cursor: pointer;
    user-select: none;
  }
}

/* ── Photos section ──────────────────────────────────────────────────────── */
.ae-photos-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;

  .ae-label { margin-bottom: 0; }
}

/* ── Photo grid ──────────────────────────────────────────────────────────── */
.ae-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

/* :global because thumbnails are injected dynamically by JS and won't carry
   Astro's scoped CSS data attribute. */
:global(.ae-thumb) {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 6px;
  background: var(--bg-sunken);
}

:global(.ae-thumb img) {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

:global(.ae-thumb-remove) {
  position: absolute;
  top: 5px;
  right: 5px;
  width: 24px;
  height: 24px;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 15px;
  line-height: 1;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 150ms ease;
}

:global(.ae-thumb-remove:hover) {
  background: rgba(0, 0, 0, 0.85);
}

/* ── Status overlay (uploading / failed) ──────────────────────────────────
   The overlay sits above the <img> and below the action buttons; its
   visibility is driven by data-status on the parent cell so we don't
   need duplicate classes per state. Three states:
     done       — overlay transparent, only × visible
     uploading  — soft black tint + a circular progress ring
     failed     — solid red tint, retry button takes the spotlight   */
:global(.ae-thumb-overlay) {
  position: absolute;
  inset: 0;
  pointer-events: none;
  transition: background-color 180ms ease;
}
:global(.ae-thumb[data-status="uploading"] .ae-thumb-overlay) {
  background: rgba(0, 0, 0, 0.35);
}
:global(.ae-thumb[data-status="failed"] .ae-thumb-overlay) {
  background: rgba(217, 79, 79, 0.55);
}

:global(.ae-thumb-progress) {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}
:global(.ae-ring-track) {
  fill: none;
  stroke: rgba(255, 255, 255, 0.3);
  stroke-width: 3;
}
:global(.ae-ring-bar) {
  fill: none;
  stroke: #fff;
  stroke-width: 3;
  stroke-linecap: round;
  transition: stroke-dashoffset 120ms linear;
}

:global(.ae-thumb-retry) {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 36px;
  height: 36px;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 150ms ease;
}
:global(.ae-thumb-retry:hover) {
  background: rgba(0, 0, 0, 0.85);
}

/* ── Mobile ──────────────────────────────────────────────────────────────── */
@media (max-width: 480px) {
  .ae-header {
    padding: calc(var(--safe-top, 0px) + 12px) 14px 12px;
    gap: 8px;
  }

  .ae-back span { display: none; }

  .ae-body {
    padding: 18px 14px 60px;
    gap: 16px;
  }

  .ae-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }
}
</style>
