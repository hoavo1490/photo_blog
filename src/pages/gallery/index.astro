---
import { env } from 'cloudflare:workers';
import BaseLayout from '~/layouts/BaseLayout.astro';
import * as albums from '~/lib/db/albums';
import { variantKeyForKey, publicUrlForKey } from '~/lib/r2/images';

const tenant = Astro.locals.tenant!;
const driver = Astro.locals.db!;
const env_ = env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };

const all = await albums.listAlbumsWithImages(driver, { siteId: tenant.id });

function imgUrl(img: { r2Key: string; variantWidths: number[] | null }): string {
  const variants = img.variantWidths ?? [];
  for (const w of [800, 1200, 400]) {
    if (variants.includes(w)) return publicUrlForKey(variantKeyForKey(img.r2Key, w), env_);
  }
  return publicUrlForKey(img.r2Key, env_);
}

function fmtDate(d: Date): string {
  return `${d.getMonth() + 1} · ${d.getFullYear()}`;
}
---
<BaseLayout title="Gallery">
  <div class="gi">
    {all.length === 0 ? (
      <p class="gi-empty">No albums yet.</p>
    ) : all.map((album) => (
      <div class="gi-album">
        <div class="gi-row">
          <a href={`/gallery/${album.slug}`} class="gi-title">{album.title}</a>
          <span class="gi-date">{fmtDate(album.createdAt)}</span>
        </div>
        {album.images.length > 0 && (
          <a href={`/gallery/${album.slug}`} class="gi-masonry" aria-label={`View ${album.title}`}>
            {album.images.map((img) => (
              <img
                src={imgUrl(img)}
                alt={img.caption ?? ''}
                loading="lazy"
                width={img.width}
                height={img.height}
              />
            ))}
          </a>
        )}
      </div>
    ))}
  </div>
</BaseLayout>
