---
import { env } from 'cloudflare:workers';
import BaseLayout from '~/layouts/BaseLayout.astro';
import * as albums from '~/lib/db/albums';
import { variantKeyForKey, publicUrlForKey } from '~/lib/r2/images';

const tenant = Astro.locals.tenant!;
const driver = Astro.locals.db!;
const env_ = env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };

const all = await albums.listAlbumsWithImages(driver, { siteId: tenant.id });

function thumbUrl(img: { r2Key: string; variantWidths: number[] | null }): string {
  const variants = img.variantWidths ?? [];
  for (const w of [400, 800, 1200]) {
    if (variants.includes(w)) return publicUrlForKey(variantKeyForKey(img.r2Key, w), env_);
  }
  return publicUrlForKey(img.r2Key, env_);
}

function fmtDate(d: Date): string {
  const mon = d.toLocaleString('en-US', { month: 'short' }).toUpperCase();
  return `${mon} · ${d.getFullYear()}`;
}
---
<BaseLayout title="Gallery">
  <div class="gallery-index">
    {all.length === 0 ? (
      <p class="gallery-empty">No albums yet.</p>
    ) : (
      <div class="gallery-list">
        {all.map((album) => (
          <div class="gallery-entry">
            <div class="gallery-entry-header">
              <a href={`/gallery/${album.slug}`} class="gallery-entry-title">
                {album.title}
              </a>
              <span class="gallery-entry-date">{fmtDate(album.createdAt)}</span>
            </div>
            {album.images.length > 0 && (
              <div class="gallery-entry-thumbs">
                {album.images.slice(0, 5).map((img) => (
                  <a href={`/gallery/${album.slug}`} class="gallery-thumb">
                    <img
                      src={thumbUrl(img)}
                      alt={img.caption ?? ''}
                      loading="lazy"
                    />
                  </a>
                ))}
                {album.images.length > 5 && (
                  <a href={`/gallery/${album.slug}`} class="gallery-thumb gallery-thumb-more">
                    <span>+{album.images.length - 5}</span>
                  </a>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
