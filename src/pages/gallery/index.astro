---
import { env } from 'cloudflare:workers';
import BaseLayout from '~/layouts/BaseLayout.astro';
import * as albums from '~/lib/db/albums';
import { variantKeyForKey, publicUrlForKey } from '~/lib/r2/images';

const tenant = Astro.locals.tenant!;
const driver = Astro.locals.db!;
const env_ = env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };

const all = await albums.listAlbumsWithImages(driver, { siteId: tenant.id });

function thumbUrl(img: { r2Key: string; variantWidths: number[] | null }): string {
  const variants = img.variantWidths ?? [];
  for (const w of [800, 1200, 400]) {
    if (variants.includes(w)) {
      return publicUrlForKey(variantKeyForKey(img.r2Key, w).replace(/\.jpg$/, '.webp'), env_);
    }
  }
  return publicUrlForKey(img.r2Key, env_);
}

function fullUrl(img: { r2Key: string; variantWidths: number[] | null }): string {
  const variants = img.variantWidths ?? [];
  for (const w of [1600, 1200, 800]) {
    if (variants.includes(w)) {
      return publicUrlForKey(variantKeyForKey(img.r2Key, w).replace(/\.jpg$/, '.webp'), env_);
    }
  }
  return publicUrlForKey(img.r2Key, env_);
}

function fmtDate(d: Date): string {
  return `${d.getMonth() + 1} · ${d.getFullYear()}`;
}

// Preload the first visible gallery image (LCP candidate).
const lcpThumb = all.length > 0 && all[0].images.length > 0
  ? thumbUrl(all[0].images[0])
  : undefined;
---
<BaseLayout title="Gallery" lcpImage={lcpThumb ? { src: lcpThumb } : undefined}>
  <div class="gi">
    {all.length === 0 ? (
      <p class="gi-empty">No albums yet.</p>
    ) : all.map((album, albumIdx) => (
      <div class="gi-album">
        <div class="gi-row">
          <span class="gi-title">{album.title}</span>
          <span class="gi-date">{fmtDate(album.createdAt)}</span>
        </div>
        {album.images.length > 0 && (
          <div class="gi-masonry">
            {album.images.map((img, imgIdx) => {
              const isLcp = albumIdx === 0 && imgIdx === 0;
              return (
                <a
                  href={fullUrl(img)}
                  data-pswp-src={fullUrl(img)}
                  data-pswp-width={img.width}
                  data-pswp-height={img.height}
                  aria-label={img.caption ?? `Photo ${imgIdx + 1}`}
                >
                  <img
                    src={thumbUrl(img)}
                    alt={img.caption ?? ''}
                    loading={isLcp ? 'eager' : 'lazy'}
                    decoding={isLcp ? 'sync' : 'async'}
                    fetchpriority={isLcp ? 'high' : 'auto'}
                    width={img.width}
                    height={img.height}
                  />
                </a>
              );
            })}
          </div>
        )}
      </div>
    ))}
  </div>
</BaseLayout>

<script>
import PhotoSwipeLightbox from 'photoswipe/lightbox';
import PhotoSwipe from 'photoswipe';
import 'photoswipe/style.css';

function initGalleryLightbox() {
  if (document.body.dataset.giPswpInited === '1') return;
  document.body.dataset.giPswpInited = '1';
  const lightbox = new PhotoSwipeLightbox({
    gallery: '.gi-masonry',
    children: 'a[data-pswp-src]',
    pswpModule: PhotoSwipe,
    showHideAnimationType: 'fade',
    bgOpacity: 1,
  });
  lightbox.init();
}

initGalleryLightbox();
document.addEventListener('astro:page-load', () => {
  document.body.dataset.giPswpInited = '0';
  initGalleryLightbox();
});
</script>
