---
import { env } from 'cloudflare:workers';
import BaseLayout from '~/layouts/BaseLayout.astro';
import * as albums from '~/lib/db/albums';
import { variantKeyForKey, publicUrlForKey } from '~/lib/r2/images';

const tenant = Astro.locals.tenant!;
const driver = Astro.locals.db!;
const env_ = env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };

const { slug } = Astro.params;
const album = await albums.findAlbumBySlug(driver, { siteId: tenant.id, slug: slug! });
if (!album) return Astro.redirect('/gallery');

// Build thumbnail URL for each image (pick a good variant)
function thumbUrl(img: typeof album.images[number]): string {
  const variants = img.variantWidths ?? [];
  // Pick 800w for thumbnail display, fallback to 400w, 1200w, original
  const order = [800, 400, 1200, 1600];
  for (const w of order) {
    if (variants.includes(w)) return publicUrlForKey(variantKeyForKey(img.r2Key, w), env_);
  }
  return publicUrlForKey(img.r2Key, env_);
}

function fullUrl(img: typeof album.images[number]): string {
  return publicUrlForKey(img.r2Key, env_);
}
---
<BaseLayout title={album.title}>
  <div class="album-wrap">
    <nav class="album-breadcrumb">
      <a href="/gallery">← Gallery</a>
    </nav>
    <div class="album-header">
      <h1 class="album-title">{album.title}</h1>
      {album.description && <p class="album-description">{album.description}</p>}
    </div>

    {album.images.length === 0 ? (
      <p style="color: #999; text-align: center; padding: 60px 0;">No photos in this album yet.</p>
    ) : (
      <div class="album-images" id="album-grid">
        {album.images.map((img) => (
          <div style={`width: ${img.width}px; height: ${img.height}px`}>
            <a
              href={fullUrl(img)}
              data-pswp-src={fullUrl(img)}
              data-pswp-width={img.width}
              data-pswp-height={img.height}
            >
              <img
                src={thumbUrl(img)}
                alt={img.caption ?? ''}
                loading="lazy"
                style="width: 100%; height: 100%; object-fit: cover; display: block;"
              />
            </a>
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<script>
import { initGallery } from '~/scripts/gallery-lightbox';
initGallery();
document.addEventListener('astro:page-load', initGallery);
</script>

<style>
.album-wrap {
  margin: 0 auto;
  padding: 0 8px 4em;
}
.album-breadcrumb {
  margin: 1.5em 0 1em;
  font-size: 0.85em;
}
.album-breadcrumb a {
  color: #bb2222;
}
.album-header {
  margin: 0 0 2em 0;
  max-width: 750px;
}
.album-title {
  font-size: 1.6em;
  font-weight: 700;
  line-height: 1.3;
  color: #333;
}
.album-description {
  margin-top: 0.5em;
  font-size: 0.95em;
  color: #666;
  line-height: 1.5;
}
.album-images {
  margin-top: 1em;
}
.album-images > div {
  display: inline-block;
}
.album-images a {
  display: block;
  width: 100%;
  height: 100%;
  overflow: hidden;
}
</style>
