---
import { env } from 'cloudflare:workers';
import BaseLayout from '~/layouts/BaseLayout.astro';
import * as albums from '~/lib/db/albums';
import { variantKeyForKey, publicUrlForKey } from '~/lib/r2/images';

const tenant = Astro.locals.tenant!;
const driver = Astro.locals.db!;
const env_ = env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };

const { slug } = Astro.params;
const album = await albums.findAlbumBySlug(driver, { siteId: tenant.id, slug: slug! });
if (!album) return Astro.redirect('/gallery');

function thumbUrl(img: typeof album.images[number]): string {
  const variants = img.variantWidths ?? [];
  for (const w of [800, 400, 1200, 1600]) {
    if (variants.includes(w)) return publicUrlForKey(variantKeyForKey(img.r2Key, w), env_);
  }
  return publicUrlForKey(img.r2Key, env_);
}
---
<BaseLayout title={album.title}>
  <div id="foto-gallery">
    <div class="foto-section" id={album.slug}>
      <div class="foto-section-header">
        <div class="foto-section-title">{album.title}</div>
        {album.description && <div class="foto-section-description">{album.description}</div>}
      </div>
      {album.images.length === 0 ? (
        <p style="color: #999; padding: 2em 0 4em 4em;">No photos in this album yet.</p>
      ) : (
        <div class={`section-images section-images-${album.slug}`}>
          {album.images.map(img => (
            <div style={`width: ${img.width}px; height: ${img.height}px`}>
              <a
                href={publicUrlForKey(img.r2Key, env_)}
                data-pswp-src={publicUrlForKey(img.r2Key, env_)}
                data-pswp-width={img.width}
                data-pswp-height={img.height}
              >
                <img
                  src={thumbUrl(img)}
                  alt={img.caption ?? ''}
                  loading="lazy"
                  style="width: 100%; height: 100%; object-fit: cover; display: block;"
                />
              </a>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<script>
import { initGallery } from '~/scripts/gallery-lightbox';
initGallery();
document.addEventListener('astro:page-load', initGallery);
</script>
