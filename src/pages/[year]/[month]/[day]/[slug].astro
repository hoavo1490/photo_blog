---
import PostLayout from '../../../../layouts/PostLayout.astro';
import * as posts from '../../../../lib/db/posts';

const tenant = Astro.locals.tenant!;
const driver = Astro.locals.db!;
const { year, month, day, slug } = Astro.params as Record<string, string>;

// Validate URL parts inline; defense against direct manipulation.
if (!/^\d{4}$/.test(year) || !/^\d{2}$/.test(month) || !/^\d{2}$/.test(day)) {
  return new Response('Not found', { status: 404 });
}

// .html suffix may or may not be present depending on routing config.
const cleanSlug = slug.replace(/\.html$/, '');
const post = await posts.findByPath(driver, {
  siteId: tenant.id, year, month, day, slug: cleanSlug,
});
if (!post) return new Response('Not found', { status: 404 });
---
<PostLayout post={post} />
