---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import * as posts from '../lib/db/posts';
import { coverImageFor } from '../lib/render';
import { firstParagraph } from '../lib/markdown';

const tenant = Astro.locals.tenant!;
const driver = Astro.locals.db!;
const env_ = env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };

const all = await posts.listPublished(driver, { siteId: tenant.id, limit: 200 });

type Card = {
  post: typeof all[number];
  cover: string;
  desc: string;
  r2Key: string | null;
  variantWidths: number[];
};
const cards: Card[] = [];
for (const p of all) {
  const info = await coverImageFor(driver, p, env_);
  if (!info) continue;
  const desc = p.description ?? firstParagraph(p.body) ?? '';
  cards.push({ post: p, cover: info.url, desc, r2Key: info.r2Key, variantWidths: info.variantWidths });
}

const byYear = new Map<number, Card[]>();
for (const c of cards) {
  const y = c.post.publishedAt!.getUTCFullYear();
  const list = byYear.get(y) ?? [];
  list.push(c);
  byYear.set(y, list);
}
const years = [...byYear.entries()].sort((a, b) => b[0] - a[0]);

// og:image = latest post's cover so social shares of the home page get
// a real image preview instead of a blank card.
const latestCover = cards[0]?.cover;
const latestDesc = cards[0]?.desc;
---
<BaseLayout
  description={latestDesc || undefined}
  image={latestCover}
>
  <div class="home-wrap">
    <div id="gallery" class="gallery">
      {years.map(([year, list]) => (
        <section class="year-section" data-year={year}>
          <div class="section-header-wrapper">
            <div class="section-title">{year}</div>
          </div>
          <div class="section-images">
            {list.map((c) => (
              <PostCard
                post={c.post}
                cover={c.cover}
                description={c.desc}
                priority={cards[0]?.post.id === c.post.id}
                variantWidths={c.variantWidths}
                r2Key={c.r2Key ?? undefined}
                r2Env={env_}
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
