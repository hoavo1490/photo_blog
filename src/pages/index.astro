---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import * as posts from '../lib/db/posts';
import { batchCoverImagesFor } from '../lib/render';
import { firstParagraph } from '../lib/markdown';
import { variantUrlForKey } from '../lib/r2/images';

const tenant = Astro.locals.tenant!;
const driver = Astro.locals.db!;
const env_ = env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };

const all = await posts.listPublished(driver, { siteId: tenant.id, limit: 200 });
const coverByPost = await batchCoverImagesFor(driver, tenant.id, all, env_);

type Card = {
  post: typeof all[number];
  cover: string;
  desc: string;
  r2Key: string | null;
  variantWidths: number[];
  hasAvif: boolean;
};
const cards: Card[] = [];
for (const p of all) {
  const info = coverByPost.get(p.id);
  if (!info) continue;
  const desc = p.description ?? firstParagraph(p.body) ?? '';
  cards.push({
    post: p, cover: info.url, desc,
    r2Key: info.r2Key, variantWidths: info.variantWidths, hasAvif: info.hasAvif,
  });
}

const byYear = new Map<number, Card[]>();
for (const c of cards) {
  const y = c.post.publishedAt!.getUTCFullYear();
  const list = byYear.get(y) ?? [];
  list.push(c);
  byYear.set(y, list);
}
const years = [...byYear.entries()].sort((a, b) => b[0] - a[0]);

// og:image = latest post's cover so social shares of the home page get
// a real image preview instead of a blank card.
const latestCover = cards[0]?.cover;
const latestDesc = cards[0]?.desc;
const latest = cards[0];
const lcpSizes = '(max-width: 480px) 100vw, (max-width: 800px) 50vw, 250px';
const lcpSrcset = latest && latest.r2Key && latest.variantWidths.length > 0
  ? [
      ...latest.variantWidths.map((w) => `${variantUrlForKey(latest.r2Key!, w, env_)} ${w}w`),
      `${latest.cover} 1600w`,
    ].join(', ')
  : undefined;
const lcpWebpSrcset = latest && latest.r2Key && latest.variantWidths.length > 0
  ? latest.variantWidths
      .map((w) => `${variantUrlForKey(latest.r2Key!, w, env_).replace(/\.jpg$/, '.webp')} ${w}w`)
      .join(', ')
  : undefined;
const lcpAvifSrcset = latest && latest.r2Key && latest.hasAvif && latest.variantWidths.length > 0
  ? latest.variantWidths
      .map((w) => `${variantUrlForKey(latest.r2Key!, w, env_).replace(/\.jpg$/, '.avif')} ${w}w`)
      .join(', ')
  : undefined;
---
<BaseLayout
  description={latestDesc || undefined}
  image={latestCover}
  lcpImage={latest ? {
    src: latest.cover,
    srcset: lcpSrcset,
    webpSrcset: lcpWebpSrcset,
    avifSrcset: lcpAvifSrcset,
    sizes: lcpSrcset ? lcpSizes : undefined,
  } : undefined}
>
  <div class="home-wrap">
    <div id="gallery" class="gallery">
      {years.map(([year, list]) => (
        <section class="year-section" data-year={year}>
          <div class="section-header-wrapper">
            <div class="section-title">{year}</div>
          </div>
          <div class="section-images">
            {list.map((c) => (
              <PostCard
                post={c.post}
                cover={c.cover}
                description={c.desc}
                priority={cards[0]?.post.id === c.post.id}
                variantWidths={c.variantWidths}
                r2Key={c.r2Key ?? undefined}
                r2Env={env_}
                hasAvif={c.hasAvif}
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
