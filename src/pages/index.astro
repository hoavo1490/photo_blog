---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { firstImage, firstParagraph } from '../utils/extract';

const all = await getCollection('posts');

type Card = { post: typeof all[number]; cover: string; desc: string };
const cards: Card[] = [];
for (const p of all) {
  const cover = p.data.cover ?? firstImage(p.body ?? '');
  if (!cover) continue;
  const desc = p.data.description ?? firstParagraph(p.body ?? '') ?? '';
  cards.push({ post: p, cover, desc });
}
cards.sort((a, b) => b.post.data.date.getTime() - a.post.data.date.getTime());

// Group by year manually so we can carry desc/cover through.
const byYear = new Map<number, Card[]>();
for (const c of cards) {
  const y = c.post.data.date.getUTCFullYear();
  const list = byYear.get(y) ?? [];
  list.push(c);
  byYear.set(y, list);
}
const years = [...byYear.entries()].sort((a, b) => b[0] - a[0]);
---
<BaseLayout>
  <div class="home-wrap">
    <div id="gallery" class="gallery">
      {years.map(([year, list]) => (
        <section class="year-section" data-year={year}>
          <div class="section-header-wrapper">
            <div class="section-title">{year}</div>
          </div>
          <div class="section-images">
            {list.map((c) => <PostCard post={c.post} cover={c.cover} desc={c.desc} />)}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
