---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import PostForm from '../../../components/PostForm.astro';
import * as posts from '../../../lib/db/posts';
import type { SqlDriver } from '../../../lib/db/driver';
import { publicUrlForKey, editorPreviewUrlForKey } from '../../../lib/r2/images';
import { allImageTokens } from '../../../lib/markdown';

const session = Astro.locals.session;
if (!session) return Astro.redirect('/login');
const driver = Astro.locals.db! as SqlDriver;

const sites = await driver.query<{ id: string }>(
  `SELECT s.id FROM sites s JOIN site_members m ON m.site_id = s.id
   WHERE m.user_id = $1 ORDER BY m.added_at ASC LIMIT 1`,
  [session.userId],
);
if (sites.length === 0) return new Response('No sites', { status: 403 });
const siteId = sites[0].id;
const postId = Astro.params.id!;

const post = await posts.findById(driver, { siteId, id: postId });
if (!post) return new Response('Post not found', { status: 404 });

const tagRows = await driver.query<{ name: string }>(
  `SELECT t.name FROM tags t JOIN post_tags pt ON pt.tag_id = t.id
   WHERE pt.post_id = $1 ORDER BY t.slug`,
  [postId],
);
const tagNames = tagRows.map((r) => r.name);

// Resolve current cover URL (if any) so the editor can show a thumbnail.
let coverUrl: string | null = null;
if (post.coverImageId) {
  const rows = await driver.query<{ r2_key: string }>(
    `SELECT r2_key FROM images WHERE site_id = $1 AND id = $2`,
    [siteId, post.coverImageId],
  );
  if (rows[0]) {
    coverUrl = publicUrlForKey(
      rows[0].r2_key,
      env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string },
    );
  }
}

// Resolve every `image:<uuid>` token in the body to its public URL so
// the editor can render images inline (Milkdown sees them as normal
// <img>s). On save the client collapses URLs back to tokens.
const bodyTokens = allImageTokens(post.body);
const r2Env_ = env as unknown as { R2_PUBLIC_BASE?: string; R2_DEV_BASE?: string };
type ImageEntry = { id: string; url: string };
const bodyImages: ImageEntry[] = [];
if (bodyTokens.length > 0) {
  const placeholders = bodyTokens.map((_, i) => `$${i + 2}`).join(',');
  const rows = await driver.query<{ id: string; r2_key: string; variant_widths: number[] | null }>(
    `SELECT id, r2_key, variant_widths FROM images WHERE site_id = $1 AND id IN (${placeholders})`,
    [siteId, ...bodyTokens],
  );
  for (const r of rows) {
    // Editor renders a smaller variant (800w preferred) so loads are
    // snappy. We also register the canonical /img/<key> URL so existing
    // bodies that already reference the primary still collapse to tokens
    // on save.
    const widths = (r.variant_widths ?? []).map((n) => typeof n === 'string' ? parseInt(n, 10) : n);
    const editorUrl = editorPreviewUrlForKey(r.r2_key, widths);
    const canonicalUrl = publicUrlForKey(r.r2_key, r2Env_);
    // Push the canonical first so urlToUuid covers both URLs, then the
    // editor URL last so uuidToUrl resolves tokens to the small variant
    // (buildImageMapping is last-write-wins for the forward direction).
    if (editorUrl !== canonicalUrl) bodyImages.push({ id: r.id, url: canonicalUrl });
    bodyImages.push({ id: r.id, url: editorUrl });
  }
}
---
<AdminLayout title={post.title || 'edit'}>
  <PostForm
    mode="edit"
    siteId={siteId}
    initial={{ ...post, tagNames, coverUrl, bodyImages }}
  />
</AdminLayout>
