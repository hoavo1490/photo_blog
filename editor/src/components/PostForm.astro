---
import { newGuid } from '../lib/post';

interface Props {
  mode: 'new' | 'edit';
  initial: {
    title: string;
    date: string;
    tags: string[];
    body: string;
    cover?: string;
    description?: string;
    guid?: string;
    slug?: string;     // edit-only
    sha?: string;      // edit-only
  };
}
const { mode, initial } = Astro.props;
const today = new Date().toISOString().slice(0, 10);
const guid = initial.guid ?? newGuid();
---
<form id="post-form" method="post" action="/api/save">
  <input type="hidden" name="mode" value={mode} />
  <input type="hidden" name="guid" value={guid} />
  {initial.slug && <input type="hidden" name="originalSlug" value={initial.slug} />}
  {initial.sha && <input type="hidden" name="sha" value={initial.sha} />}

  <label style="display: block; margin-bottom: 14px;">
    <div style="font-size: 13px; color: var(--muted); margin-bottom: 4px;">title</div>
    <input name="title" required value={initial.title} placeholder="post title" />
  </label>

  <label style="display: block; margin-bottom: 14px;">
    <div style="font-size: 13px; color: var(--muted); margin-bottom: 4px;">date</div>
    <input name="date" type="date" required value={initial.date || today} />
  </label>

  <label style="display: block; margin-bottom: 14px;">
    <div style="font-size: 13px; color: var(--muted); margin-bottom: 4px;">tags (comma-separated)</div>
    <input name="tags" value={initial.tags.join(', ')} placeholder="photography, leica" />
  </label>

  <label style="display: block; margin-bottom: 14px;">
    <div style="font-size: 13px; color: var(--muted); margin-bottom: 4px;">cover image (optional override)</div>
    <input name="cover" value={initial.cover ?? ''} placeholder="/media/files/2026/06/14/foo.jpg" />
  </label>

  <div style="margin-bottom: 8px;">
    <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
      <label style="
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        min-height: 48px; padding: 0 20px;
        border: 1px solid var(--border); border-radius: 999px;
        cursor: pointer; background: var(--bg-elev);
        font-weight: 500;
        flex: 1; min-width: 140px; max-width: 240px;
      ">
        <span aria-hidden="true">📷</span>
        <span>add photo</span>
        <input id="image-picker" type="file" accept="image/*" multiple style="display: none;" />
      </label>
      <label style="
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        min-height: 48px; padding: 0 20px;
        border: 1px solid var(--border); border-radius: 999px;
        cursor: pointer; background: var(--bg-elev);
      ">
        <span aria-hidden="true">📸</span>
        <span>take photo</span>
        <input id="camera-picker" type="file" accept="image/*" capture="environment" style="display: none;" />
      </label>
    </div>
    <div id="image-status" style="
      font-size: 13px; color: var(--muted); margin-top: 8px;
      min-height: 1.4em;
    "></div>
  </div>

  <label style="display: block; margin-bottom: 14px;">
    <div style="font-size: 13px; color: var(--muted); margin-bottom: 4px;">
      body (markdown) — paste or drop an image to insert
    </div>
    <textarea
      id="body-area"
      name="body"
      rows="14"
      placeholder="write here…"
      style="min-height: 320px;"
    >{initial.body}</textarea>
  </label>

  <div class="save-bar">
    <div>
      {mode === 'edit' && (
        <button type="button" class="danger" id="delete-btn">delete</button>
      )}
    </div>
    <div class="right">
      <button type="button" onclick="history.back()">cancel</button>
      <button type="submit" class="primary" id="save-btn">save</button>
    </div>
  </div>
</form>

<script>
  import { compressImage, blobToBase64, formatBytes, filenameFromOriginal } from '../lib/compress';

  const form = document.getElementById('post-form') as HTMLFormElement;
  const picker = document.getElementById('image-picker') as HTMLInputElement;
  const cameraPicker = document.getElementById('camera-picker') as HTMLInputElement;
  const status = document.getElementById('image-status') as HTMLElement;
  const body = document.getElementById('body-area') as HTMLTextAreaElement;
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
  const deleteBtn = document.getElementById('delete-btn') as HTMLButtonElement | null;

  // Track IME composition so we don't process pastes mid-composition.
  let isComposing = false;
  body.addEventListener('compositionstart', () => { isComposing = true; });
  body.addEventListener('compositionend', () => { isComposing = false; });

  function insertAtCursor(text: string) {
    const at = body.selectionStart ?? body.value.length;
    const end = body.selectionEnd ?? at;
    body.value = body.value.slice(0, at) + text + body.value.slice(end);
    const cursor = at + text.length;
    body.selectionStart = body.selectionEnd = cursor;
    body.focus();
  }

  async function handleFile(file: File) {
    if (!file.type.startsWith('image/')) {
      status.textContent = `not an image: ${file.type || 'unknown'}`;
      return;
    }

    const placeholder = `\n![uploading ${file.name}…](#uploading)\n`;
    insertAtCursor(placeholder);
    const placeholderStart = body.value.indexOf(placeholder);
    status.textContent = `compressing ${file.name} (${formatBytes(file.size)})…`;

    let compressed;
    try {
      compressed = await compressImage(file, { maxEdge: 1600, quality: 0.85 });
    } catch (e: any) {
      replacePlaceholder(placeholder, placeholderStart, '');
      status.textContent = `compress failed: ${e.message ?? e}`;
      return;
    }

    const savings = file.size > 0
      ? Math.round(100 - (compressed.compressedSize / file.size) * 100)
      : 0;
    status.textContent =
      `uploading ${formatBytes(file.size)} → ${formatBytes(compressed.compressedSize)} (-${savings}%)…`;

    const filename = filenameFromOriginal(file.name, compressed.blob);
    const base64 = await blobToBase64(compressed.blob);

    try {
      const r = await fetch('/api/upload', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ filename, base64 }),
      });
      if (!r.ok) throw new Error(await r.text());
      const { url } = await r.json();
      const alt = file.name.replace(/\.[^.]+$/, '');
      const finalMarkdown = `\n![${alt}](${url})\n`;
      replacePlaceholder(placeholder, placeholderStart, finalMarkdown);
      status.textContent = `inserted ${url} (${formatBytes(compressed.compressedSize)})`;
    } catch (e: any) {
      replacePlaceholder(placeholder, placeholderStart, '');
      status.textContent = `upload failed: ${e.message ?? e}`;
    }
  }

  function replacePlaceholder(placeholder: string, knownIndex: number, replacement: string) {
    const i = knownIndex >= 0 ? knownIndex : body.value.indexOf(placeholder);
    if (i < 0) return;
    body.value = body.value.slice(0, i) + replacement + body.value.slice(i + placeholder.length);
    const cursor = i + replacement.length;
    body.selectionStart = body.selectionEnd = cursor;
  }

  // Library picker (multi-select). Uploads sequentially so the status line
  // stays legible and we don't fire N parallel commits against GitHub.
  async function handlePicker(input: HTMLInputElement) {
    const files = Array.from(input.files ?? []);
    input.value = '';
    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      if (files.length > 1) status.textContent = `(${i + 1}/${files.length}) preparing ${file.name}…`;
      await handleFile(file);
    }
  }
  picker?.addEventListener('change', () => handlePicker(picker));
  cameraPicker?.addEventListener('change', () => handlePicker(cameraPicker));

  // Paste an image from clipboard. Skip during IME composition.
  body.addEventListener('paste', (e) => {
    if (isComposing) return;
    const items = e.clipboardData?.items;
    if (!items) return;
    for (const it of items) {
      if (it.type.startsWith('image/')) {
        const file = it.getAsFile();
        if (file) {
          e.preventDefault();
          handleFile(file);
          return;
        }
      }
    }
  });

  // Drag and drop onto the textarea.
  body.addEventListener('dragover', (e) => {
    if (e.dataTransfer?.types.includes('Files')) {
      e.preventDefault();
    }
  });
  body.addEventListener('drop', (e) => {
    const files = e.dataTransfer?.files;
    if (!files?.length) return;
    e.preventDefault();
    for (const f of files) {
      if (f.type.startsWith('image/')) {
        handleFile(f);
        break;  // one at a time to keep status legible
      }
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveBtn.textContent = 'saving…';
    const fd = new FormData(form);
    const payload: any = {
      mode: fd.get('mode'),
      title: fd.get('title'),
      date: fd.get('date'),
      tags: String(fd.get('tags') ?? '').split(',').map((s) => s.trim()).filter(Boolean),
      cover: fd.get('cover') || undefined,
      guid: fd.get('guid'),
      body: fd.get('body') ?? '',
    };
    if (fd.get('originalSlug')) payload.originalSlug = fd.get('originalSlug');
    if (fd.get('sha')) payload.sha = fd.get('sha');
    try {
      const r = await fetch('/api/save', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!r.ok) throw new Error(await r.text());
      const { slug } = await r.json();
      location.href = `/edit/${slug}`;
    } catch (e: any) {
      saveBtn.disabled = false;
      saveBtn.textContent = 'save';
      alert('save failed: ' + (e.message ?? e));
    }
  });

  deleteBtn?.addEventListener('click', async () => {
    const slug = (form.elements.namedItem('originalSlug') as HTMLInputElement | null)?.value;
    const sha = (form.elements.namedItem('sha') as HTMLInputElement | null)?.value;
    if (!slug || !sha) return;
    if (!confirm(`delete "${slug}"? this commits a deletion to the repo.`)) return;
    try {
      const r = await fetch('/api/delete', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ slug, sha }),
      });
      if (!r.ok) throw new Error(await r.text());
      location.href = '/';
    } catch (e: any) {
      alert('delete failed: ' + (e.message ?? e));
    }
  });
</script>
