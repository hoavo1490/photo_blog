---
import { newGuid } from '../lib/post';

interface Props {
  mode: 'new' | 'edit';
  initial: {
    title: string;
    date: string;
    tags: string[];
    body: string;
    cover?: string;
    description?: string;
    guid?: string;
    slug?: string;     // edit-only
    sha?: string;      // edit-only
  };
}
const { mode, initial } = Astro.props;
const today = new Date().toISOString().slice(0, 10);
const guid = initial.guid ?? newGuid();
---
<form id="post-form" method="post" action="/api/save">
  <input type="hidden" name="mode" value={mode} />
  <input type="hidden" name="guid" value={guid} />
  {initial.slug && <input type="hidden" name="originalSlug" value={initial.slug} />}
  {initial.sha && <input type="hidden" name="sha" value={initial.sha} />}

  <label style="display: block; margin-bottom: 14px;">
    <div style="font-size: 13px; color: var(--muted); margin-bottom: 4px;">title</div>
    <input name="title" required value={initial.title} placeholder="post title" />
  </label>

  <label style="display: block; margin-bottom: 14px;">
    <div style="font-size: 13px; color: var(--muted); margin-bottom: 4px;">date</div>
    <input name="date" type="date" required value={initial.date || today} />
  </label>

  <label style="display: block; margin-bottom: 14px;">
    <div style="font-size: 13px; color: var(--muted); margin-bottom: 4px;">tags (comma-separated)</div>
    <input name="tags" value={initial.tags.join(', ')} placeholder="photography, leica" />
  </label>

  <label style="display: block; margin-bottom: 14px;">
    <div style="font-size: 13px; color: var(--muted); margin-bottom: 4px;">cover image (optional override)</div>
    <input name="cover" value={initial.cover ?? ''} placeholder="/media/files/2026/06/14/foo.jpg" />
  </label>

  <div style="margin-bottom: 8px;">
    <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
      <label style="
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        min-height: 48px; padding: 0 20px;
        border: 1px solid var(--border); border-radius: 999px;
        cursor: pointer; background: var(--bg-elev);
        font-weight: 500;
        flex: 1; min-width: 140px; max-width: 240px;
      ">
        <span aria-hidden="true">📷</span>
        <span>add photo</span>
        <input id="image-picker" type="file" accept="image/*" multiple style="display: none;" />
      </label>
      <label style="
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        min-height: 48px; padding: 0 20px;
        border: 1px solid var(--border); border-radius: 999px;
        cursor: pointer; background: var(--bg-elev);
      ">
        <span aria-hidden="true">📸</span>
        <span>take photo</span>
        <input id="camera-picker" type="file" accept="image/*" capture="environment" style="display: none;" />
      </label>
    </div>
    <div id="image-status" style="
      font-size: 13px; color: var(--muted); margin-top: 8px;
      min-height: 1.4em;
    "></div>
  </div>

  <div style="margin-bottom: 14px;">
    <div style="font-size: 13px; color: var(--muted); margin-bottom: 6px;">body</div>

    <div class="editor-tabs" role="tablist" style="
      display: flex; gap: 4px; margin-bottom: 8px;
      border-bottom: 1px solid var(--border);
    ">
      <button type="button" class="tab active" data-tab="write" role="tab">write</button>
      <button type="button" class="tab" data-tab="preview" role="tab">preview</button>
    </div>

    <div id="write-pane">
      <div class="toolbar" role="toolbar" aria-label="format" style="
        display: flex; flex-wrap: wrap; gap: 4px;
        padding: 6px; margin-bottom: 6px;
        background: var(--bg-elev);
        border: 1px solid var(--border); border-radius: 8px;
      ">
        <button type="button" class="tb" data-cmd="bold" title="bold (⌘B)"><b>B</b></button>
        <button type="button" class="tb" data-cmd="italic" title="italic (⌘I)"><i>I</i></button>
        <button type="button" class="tb" data-cmd="h2" title="heading">H</button>
        <button type="button" class="tb" data-cmd="quote" title="quote">❝</button>
        <button type="button" class="tb" data-cmd="ul" title="bulleted list">•</button>
        <button type="button" class="tb" data-cmd="ol" title="numbered list">1.</button>
        <button type="button" class="tb" data-cmd="link" title="link (⌘K)">🔗</button>
        <button type="button" class="tb" data-cmd="code" title="inline code">{`</>`}</button>
        <button type="button" class="tb" data-cmd="hr" title="divider">—</button>
      </div>
      <textarea
        id="body-area"
        name="body"
        rows="14"
        placeholder="write here…"
        style="min-height: 320px;"
      >{initial.body}</textarea>
    </div>

    <div id="preview-pane" class="preview" style="display: none;"></div>
  </div>

  <div class="save-bar">
    <div>
      {mode === 'edit' && (
        <button type="button" class="danger" id="delete-btn">delete</button>
      )}
    </div>
    <div class="right">
      <button type="button" onclick="history.back()">cancel</button>
      <button type="submit" class="primary" id="save-btn">save</button>
    </div>
  </div>
</form>

<style is:global>
  .editor-tabs .tab {
    min-height: 40px;
    padding: 0 18px;
    border: none;
    border-bottom: 2px solid transparent;
    border-radius: 0;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-size: 14px;
  }
  .editor-tabs .tab.active {
    color: var(--fg);
    border-bottom-color: var(--fg);
    font-weight: 500;
  }
  .toolbar .tb {
    min-width: 40px; min-height: 36px;
    padding: 0 10px;
    border: 1px solid transparent;
    border-radius: 6px;
    background: transparent;
    color: var(--fg);
    font-size: 14px;
    cursor: pointer;
  }
  .toolbar .tb:hover { background: rgba(0,0,0,0.05); }
  .toolbar .tb:active { background: rgba(0,0,0,0.1); }

  .preview {
    padding: 16px 18px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    min-height: 320px;
    line-height: 1.65;
    color: var(--fg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
  }
  .preview h1, .preview h2, .preview h3 {
    line-height: 1.25; margin: 1em 0 .4em;
  }
  .preview h1 { font-size: 1.5em; }
  .preview h2 { font-size: 1.25em; }
  .preview h3 { font-size: 1.1em; }
  .preview p { margin: .6em 0; }
  .preview ul, .preview ol { margin: .6em 0; padding-left: 1.4em; }
  .preview li { margin: .2em 0; }
  .preview blockquote {
    margin: .8em 0; padding: .5em 1em;
    border-left: 3px solid var(--border);
    color: var(--muted);
    background: rgba(0,0,0,0.02);
  }
  .preview img { max-width: 100%; height: auto; display: block; margin: 1em 0; border-radius: 4px; }
  .preview a { color: #0066cc; text-decoration: underline; }
  .preview code {
    background: rgba(0,0,0,0.06); padding: 1px 5px; border-radius: 3px;
    font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: .9em;
  }
  .preview pre {
    background: rgba(0,0,0,0.06); padding: 12px 14px; border-radius: 6px;
    overflow-x: auto; font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: .9em; line-height: 1.5;
  }
  .preview pre code { background: transparent; padding: 0; }
  .preview hr { border: none; border-top: 1px solid var(--border); margin: 1.5em 0; }
</style>

<script>
  import { marked } from 'marked';
  import { compressImage, blobToBase64, formatBytes, filenameFromOriginal } from '../lib/compress';

  marked.setOptions({ breaks: true, gfm: true });

  const form = document.getElementById('post-form') as HTMLFormElement;
  const picker = document.getElementById('image-picker') as HTMLInputElement;
  const cameraPicker = document.getElementById('camera-picker') as HTMLInputElement;
  const status = document.getElementById('image-status') as HTMLElement;
  const body = document.getElementById('body-area') as HTMLTextAreaElement;
  const writePane = document.getElementById('write-pane') as HTMLElement;
  const previewPane = document.getElementById('preview-pane') as HTMLElement;
  const tabs = document.querySelectorAll<HTMLButtonElement>('.editor-tabs .tab');
  const tbButtons = document.querySelectorAll<HTMLButtonElement>('.toolbar .tb');
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
  const deleteBtn = document.getElementById('delete-btn') as HTMLButtonElement | null;

  // Track IME composition so we don't process pastes mid-composition.
  let isComposing = false;
  body.addEventListener('compositionstart', () => { isComposing = true; });
  body.addEventListener('compositionend', () => { isComposing = false; });

  // -------- Tabs (write / preview) --------
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      tabs.forEach((t) => t.classList.toggle('active', t === tab));
      if (target === 'write') {
        writePane.style.display = '';
        previewPane.style.display = 'none';
      } else {
        previewPane.innerHTML = String(marked.parse(body.value || '*nothing yet*'));
        previewPane.style.display = '';
        writePane.style.display = 'none';
      }
    });
  });

  // -------- Toolbar --------
  function wrapSelection(left: string, right = left, placeholder = 'text') {
    const at = body.selectionStart ?? body.value.length;
    const end = body.selectionEnd ?? at;
    const selected = body.value.slice(at, end);
    const content = selected || placeholder;
    const replacement = left + content + right;
    body.value = body.value.slice(0, at) + replacement + body.value.slice(end);
    const cursorStart = at + left.length;
    const cursorEnd = cursorStart + content.length;
    body.selectionStart = cursorStart;
    body.selectionEnd = cursorEnd;
    body.focus();
  }

  function prefixLines(prefix: string) {
    const at = body.selectionStart ?? body.value.length;
    const end = body.selectionEnd ?? at;
    const before = body.value.slice(0, at);
    const selected = body.value.slice(at, end) || 'item';
    const after = body.value.slice(end);
    // Find start of current line if no selection.
    const lineStart = before.lastIndexOf('\n') + 1;
    const head = body.value.slice(lineStart, at);
    const lines = (head + selected).split('\n').map((l, i) =>
      typeof prefix === 'string' ? prefix.replace('{i}', String(i + 1)) + l : l,
    );
    const newMiddle = lines.join('\n');
    body.value = body.value.slice(0, lineStart) + newMiddle + after;
    const cursor = lineStart + newMiddle.length;
    body.selectionStart = body.selectionEnd = cursor;
    body.focus();
  }

  function insertAtCursor(text: string) {
    const at = body.selectionStart ?? body.value.length;
    const end = body.selectionEnd ?? at;
    body.value = body.value.slice(0, at) + text + body.value.slice(end);
    const cursor = at + text.length;
    body.selectionStart = body.selectionEnd = cursor;
    body.focus();
  }

  function applyCommand(cmd: string) {
    switch (cmd) {
      case 'bold': return wrapSelection('**', '**', 'bold');
      case 'italic': return wrapSelection('_', '_', 'italic');
      case 'code': return wrapSelection('`', '`', 'code');
      case 'h2': return prefixLines('## ');
      case 'quote': return prefixLines('> ');
      case 'ul': return prefixLines('- ');
      case 'ol': return prefixLines('{i}. ');
      case 'link': {
        const url = prompt('link URL', 'https://');
        if (!url) return;
        const at = body.selectionStart ?? 0;
        const end = body.selectionEnd ?? at;
        const text = body.value.slice(at, end) || 'link';
        return wrapSelection('[', `](${url})`, text);
      }
      case 'hr': return insertAtCursor('\n\n---\n\n');
    }
  }

  tbButtons.forEach((b) => b.addEventListener('click', () => applyCommand(b.dataset.cmd!)));

  // Keyboard shortcuts (⌘B, ⌘I, ⌘K). Skip during IME.
  body.addEventListener('keydown', (e) => {
    if (isComposing) return;
    if (!(e.metaKey || e.ctrlKey)) return;
    if (e.key === 'b') { e.preventDefault(); applyCommand('bold'); }
    else if (e.key === 'i') { e.preventDefault(); applyCommand('italic'); }
    else if (e.key === 'k') { e.preventDefault(); applyCommand('link'); }
  });

  // -------- Image insertion (picker / paste / drop) --------
  function replacePlaceholder(placeholder: string, knownIndex: number, replacement: string) {
    const i = knownIndex >= 0 ? knownIndex : body.value.indexOf(placeholder);
    if (i < 0) return;
    body.value = body.value.slice(0, i) + replacement + body.value.slice(i + placeholder.length);
    const cursor = i + replacement.length;
    body.selectionStart = body.selectionEnd = cursor;
  }

  async function handleFile(file: File) {
    if (!file.type.startsWith('image/')) {
      status.textContent = `not an image: ${file.type || 'unknown'}`;
      return;
    }

    const placeholder = `\n![uploading ${file.name}…](#uploading)\n`;
    insertAtCursor(placeholder);
    const placeholderStart = body.value.indexOf(placeholder);
    status.textContent = `compressing ${file.name} (${formatBytes(file.size)})…`;

    let compressed;
    try {
      compressed = await compressImage(file, { maxEdge: 1600, quality: 0.85 });
    } catch (e: any) {
      replacePlaceholder(placeholder, placeholderStart, '');
      status.textContent = `compress failed: ${e.message ?? e}`;
      return;
    }

    const savings = file.size > 0
      ? Math.round(100 - (compressed.compressedSize / file.size) * 100)
      : 0;
    status.textContent =
      `uploading ${formatBytes(file.size)} → ${formatBytes(compressed.compressedSize)} (-${savings}%)…`;

    const filename = filenameFromOriginal(file.name, compressed.blob);
    const base64 = await blobToBase64(compressed.blob);

    try {
      const r = await fetch('/api/upload', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ filename, base64 }),
      });
      if (!r.ok) throw new Error(await r.text());
      const { url } = await r.json();
      const alt = file.name.replace(/\.[^.]+$/, '');
      const finalMarkdown = `\n![${alt}](${url})\n`;
      replacePlaceholder(placeholder, placeholderStart, finalMarkdown);
      status.textContent = `inserted ${url} (${formatBytes(compressed.compressedSize)})`;
    } catch (e: any) {
      replacePlaceholder(placeholder, placeholderStart, '');
      status.textContent = `upload failed: ${e.message ?? e}`;
    }
  }

  async function handlePicker(input: HTMLInputElement) {
    const files = Array.from(input.files ?? []);
    input.value = '';
    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      if (files.length > 1) status.textContent = `(${i + 1}/${files.length}) preparing ${file.name}…`;
      await handleFile(file);
    }
  }
  picker?.addEventListener('change', () => handlePicker(picker));
  cameraPicker?.addEventListener('change', () => handlePicker(cameraPicker));

  body.addEventListener('paste', (e) => {
    if (isComposing) return;
    const items = e.clipboardData?.items;
    if (!items) return;
    for (const it of items) {
      if (it.type.startsWith('image/')) {
        const file = it.getAsFile();
        if (file) {
          e.preventDefault();
          handleFile(file);
          return;
        }
      }
    }
  });

  body.addEventListener('dragover', (e) => {
    if (e.dataTransfer?.types.includes('Files')) e.preventDefault();
  });
  body.addEventListener('drop', (e) => {
    const files = e.dataTransfer?.files;
    if (!files?.length) return;
    e.preventDefault();
    for (const f of files) {
      if (f.type.startsWith('image/')) {
        handleFile(f);
        break;
      }
    }
  });

  // -------- Save / delete --------
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveBtn.textContent = 'saving…';
    const fd = new FormData(form);
    const payload: any = {
      mode: fd.get('mode'),
      title: fd.get('title'),
      date: fd.get('date'),
      tags: String(fd.get('tags') ?? '').split(',').map((s) => s.trim()).filter(Boolean),
      cover: fd.get('cover') || undefined,
      guid: fd.get('guid'),
      body: fd.get('body') ?? '',
    };
    if (fd.get('originalSlug')) payload.originalSlug = fd.get('originalSlug');
    if (fd.get('sha')) payload.sha = fd.get('sha');
    try {
      const r = await fetch('/api/save', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!r.ok) throw new Error(await r.text());
      const { slug } = await r.json();
      location.href = `/edit/${slug}`;
    } catch (e: any) {
      saveBtn.disabled = false;
      saveBtn.textContent = 'save';
      alert('save failed: ' + (e.message ?? e));
    }
  });

  deleteBtn?.addEventListener('click', async () => {
    const slug = (form.elements.namedItem('originalSlug') as HTMLInputElement | null)?.value;
    const sha = (form.elements.namedItem('sha') as HTMLInputElement | null)?.value;
    if (!slug || !sha) return;
    if (!confirm(`delete "${slug}"? this commits a deletion to the repo.`)) return;
    try {
      const r = await fetch('/api/delete', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ slug, sha }),
      });
      if (!r.ok) throw new Error(await r.text());
      location.href = '/';
    } catch (e: any) {
      alert('delete failed: ' + (e.message ?? e));
    }
  });
</script>
