---
import EditorLayout from '../layouts/EditorLayout.astro';
import { listPosts } from '../lib/github';
import { tenant } from '../lib/config';

const env = (Astro.locals as any).runtime?.env ?? process.env;
const session = (Astro.locals as any).session as { token: string; login: string };
const t = tenant(env);
const posts = await listPosts(session.token, t);
---
<EditorLayout title="posts">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
    <h2 style="font-size: 18px; font-weight: 600;">{posts.length} posts</h2>
    <a href="/new" class="primary" role="button" style="
      min-height: 44px; padding: 10px 16px;
      background: #111; color: #fff; border-radius: 999px;
      display: inline-flex; align-items: center;
    ">+ new</a>
  </div>

  {posts.length === 0 ? (
    <p style="color: var(--muted); padding: 40px 0; text-align: center;">No posts yet. Start writing.</p>
  ) : (
    <ul style="list-style: none; padding: 0;">
      {posts.map((p) => {
        const slug = p.name.replace(/\.md$/, '');
        const m = p.name.match(/^(\d{4}-\d{2}-\d{2})-(.+)\.md$/);
        const date = m?.[1] ?? '';
        const title = m?.[2]?.replace(/-/g, ' ') ?? slug;
        return (
          <li>
            <a href={`/edit/${slug}`} style="
              display: block; padding: 14px 0;
              border-bottom: 1px solid var(--border);
            ">
              <div style="font-size: 12px; color: var(--muted); font-family: ui-monospace, monospace;">{date}</div>
              <div style="font-size: 16px; margin-top: 2px;">{title}</div>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</EditorLayout>
