---
import EditorLayout from '../../layouts/EditorLayout.astro';
import PostForm from '../../components/PostForm.astro';
import { readPost } from '../../lib/github';
import { parsePost } from '../../lib/post';
import { tenant } from '../../lib/config';

const env = (Astro.locals as any).runtime?.env ?? process.env;
const session = (Astro.locals as any).session as { token: string };
const t = tenant(env);
const slug = Astro.params.slug!;
const filename = `${slug}.md`;
const file = await readPost(session.token, t, filename);
if (!file) {
  return new Response('Post not found', { status: 404 });
}
const post = parsePost(file.content);
---
<EditorLayout title={post.title || slug}>
  <PostForm
    mode="edit"
    initial={{
      title: post.title,
      date: post.date,
      tags: post.tags,
      body: post.body,
      cover: post.cover,
      description: post.description,
      guid: post.guid,
      slug,
      sha: file.sha,
    }}
  />
</EditorLayout>
