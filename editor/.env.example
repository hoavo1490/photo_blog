# Tenant config — Phase 1 single-tenant via env. Phase 2 will move this to D1.
GITHUB_OWNER=hoavo1490
GITHUB_REPO=blog
GITHUB_BRANCH=main
CONTENT_PATH=src/content/posts
MEDIA_PATH=public/media/files

# GitHub OAuth App (create at https://github.com/settings/developers)
# Authorization callback URL during local dev: http://localhost:4321/auth/callback
# Authorization callback URL in prod:          https://editor.riovv.com/auth/callback
GITHUB_OAUTH_CLIENT_ID=replace-me
GITHUB_OAUTH_CLIENT_SECRET=replace-me

# Allowlist of GitHub logins permitted to sign in (comma-separated). Phase 2 removes
# this in favor of DB-backed per-tenant users.
ALLOWED_USERS=hoavo1490

# 32+ char random string used to AES-GCM encrypt session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Cookie domain — leave blank for localhost; set for prod.
COOKIE_DOMAIN=
